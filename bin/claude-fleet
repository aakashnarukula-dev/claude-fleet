#!/usr/bin/env bash
#
# claude-fleet — Dispatch-mode engine for the Claude Fleet app.
#
# One ORCHESTRATOR (a detached checkout at the project's default-branch tip) decomposes a goal,
# spawns its own WORKERS — each in an isolated git worktree on a session-namespaced branch — then
# integrates each worker's branch and pushes. Project knowledge lives in the repo's CLAUDE.md +
# Claude Code auto-memory (shared across all worktrees of the repo), so sessions don't start from scratch.
#
# The Electron app drives these subcommands. CLAUDE_FLEET_REPO selects the project; CLAUDE_FLEET_SESSION
# namespaces this run's worktrees/branches/status so multiple sessions don't collide.
#
#   --orchestrator         emit JSON for the solo orchestrator pane (creates the _main worktree)
#   --spawn-file H FILE [--effort L]  (orchestrator) spawn a worker; brief read from FILE — static, so auto-approved.
#                          Optional --effort L (low|medium|high|xhigh) hints the worker's reasoning effort
#                          (default = app decides, currently 'high' for workers); omit to use the default.
#   --spawn H TASK... [--effort L]     (orchestrator) spawn a worker with an inline task.
#                          Optional --effort L (low|medium|high|xhigh) — see --spawn-file.
#   --handoff T FILE       route a requirement straight INTO sibling pane T (it runs it) — no human copy-paste;
#                          RE-ARMS T as tracked PENDING work even if T was already --merged/--done (so --statuses
#                          shows it active and --next WAITS for its re-signalled --done instead of ALL DONE).
#                          FAILS LOUDLY (non-zero) if T's slug/worktree is gone — then spawn a FRESH worker.
#   --grid-plan-multi [n…] (multi-repo, no orchestrator) emit JSON for ONE named worker pane PER CLAUDE_FLEET_REPOS
#                          (optional positional headings parallel to CLAUDE_FLEET_REPOS order; blank/absent → basename)
#                          repo — each cut into its own <repo>-fleet-<sid>/<slug>, self-pushing; STATUS = shared coord
#   --grid-plan-shared N [name…]  (multi-repo, no orchestrator) emit JSON for N GENERAL worker panes, EACH spanning
#                          EVERY CLAUDE_FLEET_REPOS repo: cuts a worktree per (pane × repo) on fleet/s<sid>/<slug> + a
#                          per-pane workspace dir (<coord>/workers/<slug>/) symlinking each repo's worktree, used as the
#                          pane's cwd. Panes are NOT repo-tagged (each spans them all); self-push each repo they change.
#   --grid-plan-integrator N [name…]  (multi-repo, no orchestrator, + a dedicated INTEGRATOR pane) like
#                          --grid-plan-shared BUT workers COMMIT + --done only (never self-push); ALSO creates each repo's
#                          _main integration checkout and emits a fixed "Integrator" pane (cwd = coord dir) that
#                          INCREMENTALLY merges + test-gates + pushes each worker's change into the repos it touched.
#   --spawn-grid N FILE    (grid mode) open a NEW worker pane N seeded with the brief in FILE (no pane owned it)
#   --next                 block until a worker is ready; print its slug (or FAILED:<slug>); exit 3 = ALL DONE,
#                          exit 5 = TIMEOUT (only when CLAUDE_FLEET_NEXT_TIMEOUT>0 seconds is set)
#   --ready                print EVERY slug ready to integrate now (.done, unmerged) — enables batch integration
#   --watch                like --next but never exits on ALL DONE (waits for follow-up changes); a recorded
#                          need must persist >=CLAUDE_FLEET_NEED_GRACE sec (default 8) before it wakes the orchestrator
#   --merged S             mark slug S integrated (also clears a FAILED slug once the orchestrator has handled it)
#   --done                 (inside a worker worktree) signal finished; re-arms if it was already merged
#   --failed               (inside a worker worktree) signal it could NOT finish — orchestrator re-plans, doesn't hang
#   --conflicts            list files touched by >1 unmerged worker (pre-merge collision radar)
#   --need TEXT            (inside a worker worktree) record a prerequisite another task must produce first
#   --needs                list recorded prerequisites (slug: text) for the orchestrator to schedule
#   --unneed               (inside a worker worktree) retract a need this worker recorded by mistake
#   --status TEXT          (inside a worker worktree) post a one-line live progress note
#   --statuses             show the live progress board (slug: status) across the fleet
#   --rebuild              (orchestrator) rebuild + reinstall the project's app from the integrated state, ONCE
#                          per batch — runs .claude-fleet/rebuild or $CLAUDE_FLEET_REBUILD_CMD; no-op if neither
#   --ship-all             (multi-repo) hold-all ship: dry-run every CLAUDE_FLEET_REPOS repo's merge to origin/<DBR>;
#                          if ANY can't ff cleanly, push NOTHING. Otherwise push each in order — best-effort, not a
#                          true cross-repo transaction: a mid-sequence failure leaves earlier repos pushed but is
#                          RESUMABLE (re-run finishes the rest).
#   --ship <repo…>         (multi-repo) like --ship-all but scoped to the GIVEN repos (basename or path) — the per-worker
#                          atomic push the Integrator uses to land ONLY the repos a single worker changed (all-or-none).
#   --touched <slug>       (multi-repo) print the repos a worker slug actually CHANGED (its fleet/s<sid>/<slug> branch is
#                          ahead of that repo's _main). The Integrator scopes its --ship to exactly these.
#   --gh-align             switch the gh CLI's active account to the OWNER of origin (so osxkeychain can read/push
#                          this repo). Runs automatically at startup; this flag is the manual trigger.
#   --clean                remove this session's worktrees + branches
#   --gc                   garbage-collect FULLY-INTEGRATED <repo>-fleet[-*] session folders (folder-only). Removes a
#                          session's worktree dir ONLY when guarded: not the live session, parent repo present, every
#                          fleet/s<sid>/* branch merged into the default branch, and no worktree dirty. SKIPs otherwise.
#                          Runs automatically (same guards) when --next reports ALL DONE; CLAUDE_FLEET_NO_AUTOGC=1 opts out.
#   --gc-all [root]        like --gc but sweeps EVERY <repo>-fleet[-*] folder under a ROOT dir (default: parent of
#                          CLAUDE_FLEET_REPO, i.e. ~/Developer), deriving the parent repo + sid per folder. Reaps
#                          finished/orphaned sessions across ALL repos — folders left behind by an app quit/crash with
#                          no --next ALL DONE moment. Same G0-G4 guards; honors CLAUDE_FLEET_GC_EXCLUDE (colon-sep dirs).
#
set -euo pipefail

REPO="${CLAUDE_FLEET_REPO:-$PWD}"; REPO="${REPO%/}"   # project repo (any git repo); the app always passes CLAUDE_FLEET_REPO
SESSION="${CLAUDE_FLEET_SESSION:-}"                                        # per-tab id; isolates worktrees/branches/status
# All session worktrees live in ONE place (not scattered beside each repo). Overridable for tests.
SESSIONS_DIR="${CLAUDE_FLEET_SESSIONS_DIR:-$HOME/Developer/Fleet-Sessions}"
mkdir -p "$SESSIONS_DIR" 2>/dev/null || true
FLEET="$SESSIONS_DIR/$(basename "$REPO")-fleet${SESSION:+-$SESSION}"        # e.g. ~/Developer/Fleet-Sessions/gyftalala-fleet-1
STATUS="${CLAUDE_FLEET_STATUS_DIR:-$FLEET/.status}"                         # multi-repo: ONE shared coordination dir; single-repo: per-fleet (unchanged)
MANIFEST="$STATUS/manifest"
BR_PREFIX="fleet${SESSION:+/s$SESSION}"                                    # worker branch prefix
DBR="main"                                                                 # default branch, set by set_default_branch

die() { printf 'claude-fleet: %s\n' "$*" >&2; exit 1; }
slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//'; }
json_str() { python3 -c 'import json,sys;print(json.dumps(sys.argv[1]))' "$1"; }   # JSON-encode a string

has_origin() { git -C "$REPO" remote get-url origin >/dev/null 2>&1; }
fetch_origin() { has_origin && git -C "$REPO" fetch --prune origin >&2 2>/dev/null || true; }   # start from latest

# Align the gh CLI's active account to the OWNER of origin, so the osxkeychain github.com entry
# (which tracks gh's active account) can read/push this repo. Non-fatal, stderr-only, returns 0 always.
gh_align() (
  set +euo pipefail
  {
    command -v gh >/dev/null 2>&1 || exit 0
    url=""; owner=""; host=""; rest=""; active=""; hosts=""
    url="$(git -C "$REPO" remote get-url origin 2>/dev/null || true)"
    [ -n "$url" ] || exit 0
    case "$url" in
      git@github.com:*)            host="github.com"; rest="${url#git@github.com:}" ;;
      https://github.com/*)        host="github.com"; rest="${url#https://github.com/}" ;;
      ssh://git@github.com/*)      host="github.com"; rest="${url#ssh://git@github.com/}" ;;
      *) exit 0 ;;
    esac
    [ "$host" = "github.com" ] || exit 0
    owner="${rest%%/*}"; owner="${owner%.git}"
    [ -n "$owner" ] || exit 0
    hosts="$HOME/.config/gh/hosts.yml"
    if [ -f "$hosts" ]; then
      active="$(awk '/^github\.com:/{f=1;next} f && /^[^[:space:]]/{f=0} f && /^[[:space:]]+user:/{print $2;exit}' "$hosts" 2>/dev/null || true)"
    fi
    [ -n "$active" ] || active="$(gh auth status --active 2>/dev/null | sed -nE 's/.*Logged in to github\.com account ([^ ]+).*/\1/p' | head -1)"
    [ "$owner" = "$active" ] && exit 0
    authed=""
    if [ -f "$hosts" ]; then
      authed="$(awk '/^github\.com:/{f=1;next} f && /^[^[:space:]]/{f=0} f && /^[[:space:]]+[A-Za-z0-9_-]+:[[:space:]]*$/{gsub(/[[:space:]:]/,"");print}' "$hosts" 2>/dev/null || true)"
    fi
    if ! printf '%s\n' "$authed" | grep -qx "$owner"; then
      gh auth status 2>/dev/null | grep -q "account $owner " || exit 0
    fi
    gh auth switch --user "$owner" >/dev/null 2>&1 || true
    printf '[claude-fleet] gh active account -> %s (to match origin)\n' "$owner" >&2
  }
  exit 0
)

# Ensure the repo has a VALID git commit identity BEFORE any integrate/worker commit.
# With no user.name/user.email configured, git falls back to the machine default
# (<user>@<host>.local / "(none)") — an unverifiable author that Vercel and other CI
# REJECT ("commit author email is not valid" -> Deployment Blocked), so integrated
# work silently never deploys. Fires ONLY when the EFFECTIVE identity (local|global)
# is missing or a machine fallback — it NEVER overrides a real identity the user
# configured. Sets a REPO-LOCAL identity derived from the origin owner's GitHub
# numeric-id noreply email, which is always associated with the pushing account and
# never CI-rejected. Non-fatal, stderr-only, returns 0 always. Idempotent (a valid
# email short-circuits before any network call).
ensure_git_identity() (
  set +euo pipefail
  {
    [ -d "$REPO/.git" ] || exit 0
    email="$(git -C "$REPO" config user.email 2>/dev/null || true)"   # effective (local|global)
    case "$email" in
      ""|*.local|"(none)") : ;;          # missing or git's machine fallback -> fix below
      *) exit 0 ;;                        # a real email is already configured -> respect it
    esac
    command -v gh >/dev/null 2>&1 || exit 0
    url="$(git -C "$REPO" remote get-url origin 2>/dev/null || true)"
    case "$url" in
      git@github.com:*)       owner="${url#git@github.com:}" ;;
      https://github.com/*)   owner="${url#https://github.com/}" ;;
      ssh://git@github.com/*) owner="${url#ssh://git@github.com/}" ;;
      *) exit 0 ;;
    esac
    owner="${owner%%/*}"; owner="${owner%.git}"
    [ -n "$owner" ] || exit 0
    id="$(gh api "users/$owner" --jq .id 2>/dev/null || true)"
    if [ -n "$id" ] && [ "$id" != null ]; then
      new_email="${id}+${owner}@users.noreply.github.com"
    else
      new_email="${owner}@users.noreply.github.com"
    fi
    git -C "$REPO" config user.email "$new_email" >/dev/null 2>&1 || true
    [ -n "$(git -C "$REPO" config user.name 2>/dev/null || true)" ] \
      || git -C "$REPO" config user.name "$owner" >/dev/null 2>&1 || true
    printf '[claude-fleet] git identity for %s set -> %s <%s> (was unset/invalid; prevents CI author-blocked deploys)\n' "$(basename "$REPO")" "$owner" "$new_email" >&2
  }
  exit 0
)

set_default_branch() {
  # `|| true` is REQUIRED: under set -euo pipefail a repo with no origin/HEAD would otherwise abort silently.
  DBR="$(git -C "$REPO" symbolic-ref --quiet refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)"
  [ -n "$DBR" ] || DBR="$(git -C "$REPO" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"   # no origin -> current branch
  [ -n "$DBR" ] || DBR="main"
}

# Multi-repo: the set of cloned repo paths the super-orchestrator coordinates (colon-separated). Empty = single-repo.
REPOS_LIST="${CLAUDE_FLEET_REPOS:-}"

# Resolve a repo reference (absolute path, or a basename present in REPOS_LIST) to an absolute repo path.
# Echoes the path on success; returns non-zero (silent) if it can't be resolved.
resolve_repo() { # <name-or-path>
  local ref="$1" p IFS=:
  [ -n "$ref" ] || return 1
  if [ -d "$ref/.git" ]; then printf '%s\n' "${ref%/}"; return 0; fi
  for p in $REPOS_LIST; do
    [ -n "$p" ] || continue
    if [ "$(basename "$p")" = "$ref" ] || [ "${p%/}" = "${ref%/}" ]; then printf '%s\n' "${p%/}"; return 0; fi
  done
  return 1
}

# Re-point REPO/FLEET/DBR at a given repo for the duration of one operation (spawn into repo X, ship repo X).
# STATUS is intentionally LEFT ALONE — in multi-repo it stays the shared coordination dir (CLAUDE_FLEET_STATUS_DIR).
select_repo() { # <name-or-path>
  local p; p="$(resolve_repo "$1")" || die "unknown repo '$1' (not in CLAUDE_FLEET_REPOS and not a git dir)"
  REPO="$p"
  FLEET="$SESSIONS_DIR/$(basename "$REPO")-fleet${SESSION:+-$SESSION}"
  set_default_branch
  ensure_git_identity   # guarantee a valid commit author for this repo's worktrees (no-op if already valid)
}

# COLLISION GUARD (multi-repo): every member fleet dir, slug, and branch is keyed on basename(repo)
# (FLEET="$SESSIONS_DIR/$(basename "$REPO")-fleet-<sid>"; slug=slugify(basename)). Two SELECTED repos that
# share a basename (e.g. foo/api and bar/api) would silently map to the SAME _main/worktree/branch, so the
# 2nd repo reuses the 1st's — commits land in the WRONG repo. There is no per-repo namespacing, so we fail
# LOUD here (preferred over silent corruption) BEFORE any worktree is created. Invoked from BOTH multi-repo
# entrypoints (cmd_orchestrator multi + cmd_grid_plan_multi). bash-3.2-safe: no associative arrays — a plain
# nested scan over the (tiny) repo set; respects the existing IFS=: colon-split idiom.
assert_unique_repo_basenames() {
  local IFS=: a b ba bb
  for a in $REPOS_LIST; do
    [ -n "$a" ] || continue
    ba="$(basename "${a%/}")"
    for b in $REPOS_LIST; do
      [ -n "$b" ] || continue
      [ "${a%/}" = "${b%/}" ] && continue          # same entry (or exact-dup path) — not a real collision
      bb="$(basename "${b%/}")"
      if [ "$ba" = "$bb" ]; then
        die "multi-repo: two selected repos share the folder name '$ba' and would collide onto the same fleet dir/branch:
  - ${a%/}
  - ${b%/}
Commits for one would land in the other. Rename or deselect one so every selected repo has a unique folder name."
      fi
    done
  done
}

# DATA-LOSS FIX (2026-06-18): when there is NO 'origin' remote, the documented `git push origin HEAD:$DBR` step is
# skipped, so integrated merge commits live ONLY on the orchestrator's DETACHED `_main` HEAD — they were NEVER written
# into the canonical repo's real branch ref (refs/heads/$DBR). On teardown/prune those commits became unreachable →
# dangling → GC-pending, and shipped work silently vanished from main (we recovered a whole Android UI rewrite from
# `git fsck --lost-found`). This advances the CANONICAL branch ref to the integrated `_main` HEAD, FAST-FORWARD ONLY.
# The fleet `_main` worktree shares the canonical repo's .git object store, so the commit objects are already present;
# we only need to move the ref. Returns 0 on success/no-op, non-zero (LOUD) if it cannot safely advance — never a
# silent leave-on-detached-HEAD. No-op when an origin EXISTS (that path still ships via push, unchanged).
# Print the `git status --porcelain` lines for a worktree, EXCLUDING known-junk paths that are not real edits:
#   * a `node_modules` entry (we symlink a shared node_modules into worktrees; it can show as modified/deleted)
#   * UNTRACKED `.playwright-mcp/` artifacts (browser-mcp scratch output)
# Anything else — a modified/staged TRACKED file, or any other untracked path — is preserved, so a real edit still
# trips the clobber guard. Used by advance_canonical_branch to decide "clean enough to advance" without clobbering.
real_porcelain() { # <worktree-dir>  -> prints the offending (real-edit) porcelain lines, empty when clean-for-advance
  local wt="$1"
  git -C "$wt" status --porcelain 2>/dev/null | awk '
    {
      path = $0; sub(/^.../, "", path)    # strip the 2-char status + 1 space (porcelain v1: "XY <path>")
      # node_modules itself (top-level entry), with or without a trailing slash
      if (path == "node_modules" || path == "node_modules/") next
      # untracked .playwright-mcp artifacts ("?? .playwright-mcp/...")
      if ($0 ~ /^\?\? \.playwright-mcp\//) next
      print
    }'
}

advance_canonical_branch() {
  has_origin && return 0                                   # origin path unchanged: workers/orchestrator push to it
  local odir="$FLEET/_main"
  [ -d "$odir" ] || return 0                               # nothing integrated locally (e.g. grid mode pushes per-worker)
  set_default_branch                                       # ensure $DBR reflects the canonical default branch
  local head target
  head="$(git -C "$odir" rev-parse --verify --quiet HEAD 2>/dev/null || true)"
  [ -n "$head" ] || { printf 'claude-fleet: WARN cannot resolve _main HEAD (%s) — canonical %s NOT advanced.\n' "$odir" "$DBR" >&2; return 1; }

  if ! target="$(git -C "$REPO" rev-parse --verify --quiet "refs/heads/$DBR" 2>/dev/null)"; then
    # No local branch ref yet — create it pointing at the integrated HEAD (the commits exist; just name them).
    git -C "$REPO" update-ref "refs/heads/$DBR" "$head" \
      && { printf 'claude-fleet: created canonical %s at %s (integrated state).\n' "$DBR" "${head:0:12}" >&2; return 0; }
    printf 'claude-fleet: REFUSED — could not create canonical %s ref.\n' "$DBR" >&2; return 1
  fi

  [ "$head" = "$target" ] && return 0                       # already up to date — nothing to do

  # Locate the worktree (if any) that currently has $DBR checked out — usually the canonical repo itself. Updating
  # the ref out from under a live checkout would desync its index/working tree, so any ref move must go THROUGH it.
  local dbr_wt=""
  dbr_wt="$(git -C "$REPO" worktree list --porcelain 2>/dev/null \
    | awk -v b="refs/heads/$DBR" 'BEGIN{RS="";FS="\n"} { wt=""; for(i=1;i<=NF;i++){ if($i ~ /^worktree /) wt=substr($i,10); if($i=="branch "b){print wt; exit} } }')"

  # If $DBR is checked out, it must be clean of REAL edits before we touch it. B2: a symlinked/committed node_modules
  # showing as modified/deleted and untracked .playwright-mcp/ artifacts are NOT real edits — real_porcelain filters
  # them out. Any OTHER modified/staged tracked file (or other untracked path) still trips the clobber guard.
  local dirty=""
  if [ -n "$dbr_wt" ] && [ -d "$dbr_wt" ]; then
    dirty="$(real_porcelain "$dbr_wt")"
    if [ -n "$dirty" ]; then
      printf 'claude-fleet: REFUSED to advance canonical %s — checkout at %s has UNCOMMITTED changes:\n%s\n  To reconcile: commit or stash these in %s, then re-run (or: git -C %s merge --ff-only %s).\n' \
        "$DBR" "$dbr_wt" "$dirty" "$dbr_wt" "$dbr_wt" "${head:0:12}" >&2
      return 1
    fi
  fi

  # Is the integrated HEAD a TRUE fast-forward over $DBR (current $DBR tip is an ancestor of HEAD)?
  if git -C "$REPO" merge-base --is-ancestor "$target" "$head" 2>/dev/null; then
    # Fast-forward path.
    if [ -n "$dbr_wt" ] && [ -d "$dbr_wt" ]; then
      git -C "$dbr_wt" merge --ff-only "$head" >/dev/null 2>&1 \
        && { printf 'claude-fleet: advanced canonical %s to %s (ff in worktree %s).\n' "$DBR" "${head:0:12}" "$dbr_wt" >&2; return 0; }
      printf 'claude-fleet: REFUSED — ff of canonical %s in %s failed; resolve manually:\n  git -C %s merge --ff-only %s\n' "$DBR" "$dbr_wt" "$dbr_wt" "$head" >&2; return 1
    fi
    # $DBR is not checked out anywhere — safe to move the ref directly (ff-only, guarded above).
    git -C "$REPO" update-ref "refs/heads/$DBR" "$head" "$target" \
      && { printf 'claude-fleet: advanced canonical %s to %s (fast-forward).\n' "$DBR" "${head:0:12}" >&2; return 0; }
    printf 'claude-fleet: REFUSED — update-ref of canonical %s failed (ref moved concurrently?); resolve manually:\n  git -C %s update-ref refs/heads/%s %s\n' "$DBR" "$REPO" "$DBR" "$head" >&2; return 1
  fi

  # NON-FAST-FORWARD: the canonical branch diverged from the integrated HEAD. B1: rather than REFUSING outright, if the
  # checkout is clean of real edits, auto-reconcile with a no-ff MERGE of the integrated HEAD into $DBR (preserving all
  # commits on both sides). This needs $DBR checked out in a worktree (so the merge updates ref + tree together). On a
  # REAL conflict, abort the merge and fall back to the original REFUSED behavior — never leave a half-merged tree.
  if [ -n "$dbr_wt" ] && [ -d "$dbr_wt" ]; then
    if git -C "$dbr_wt" merge --no-ff --no-edit \
         -m "claude-fleet: integrate fleet _main ${head:0:12} into $DBR" "$head" >/dev/null 2>&1; then
      printf 'claude-fleet: reconciled canonical %s with integrated %s (no-ff merge in worktree %s).\n' "$DBR" "${head:0:12}" "$dbr_wt" >&2
      return 0
    fi
    # Merge failed (conflict or other) — abort to restore a clean tree, then refuse loudly.
    git -C "$dbr_wt" merge --abort >/dev/null 2>&1 || true
    printf 'claude-fleet: REFUSED to advance canonical %s — integrated HEAD %s is NOT a fast-forward over %s (%s) and the auto-merge hit a CONFLICT (aborted, tree restored).\n  Resolve manually in %s:\n    git -C %s merge --no-ff %s\n  then re-run; or commits will be lost on teardown.\n' \
      "$DBR" "${head:0:12}" "$DBR" "${target:0:12}" "$dbr_wt" "$dbr_wt" "$head" >&2
    return 1
  fi

  # Non-ff and $DBR is NOT checked out in any worktree — we cannot safely run a merge with a working tree. Refuse loudly
  # with the exact reconciliation command (check out $DBR somewhere, or merge in the canonical repo).
  printf 'claude-fleet: REFUSED to advance canonical %s — integrated HEAD %s is NOT a fast-forward over %s (%s) and %s is not checked out in any worktree to merge into.\n  Reconcile in the canonical repo: git -C %s merge --no-ff %s\n  before tearing down the fleet, or commits will be lost.\n' \
    "$DBR" "${head:0:12}" "$DBR" "${target:0:12}" "$DBR" "$REPO" "$head" >&2
  return 1
}

reset_state() {
  # STATUS is app-controlled (CLAUDE_FLEET_STATUS_DIR or $FLEET/.status). Assert it is a real per-session status dir
  # before the rm -rf — every other destructive path in this file path-asserts; this one must too (a misconfigured
  # STATUS=$HOME would otherwise be wiped). Must be non-empty, not / or $HOME, and end in /.status or live under a fleet dir.
  case "$STATUS" in
    ""|"/"|"$HOME"|"$HOME"/) die "refusing to reset_state: STATUS='$STATUS' is not a session status dir" ;;
  esac
  case "$STATUS" in
    */.status|"$SESSIONS_DIR"/*) : ;;
    *) die "refusing to reset_state: STATUS='$STATUS' must end in /.status or live under $SESSIONS_DIR" ;;
  esac
  rm -rf "$STATUS"; mkdir -p "$STATUS"; : > "$MANIFEST"; printf '%s\n' "$REPO" > "$STATUS/repo"
}

# symlink heavy gitignored DEPENDENCY dirs from the main checkout into a new worktree so they're SHARED, not
# copied (a worktree already shares .git; this shares node_modules/etc too) — keeps each worktree small.
# Only dependency caches (read-heavy, safe to share); NOT build outputs (dist/target) which differ per branch.
link_shared_dirs() { # <worktree-dir>
  local dir="$1" d
  [ -n "$dir" ] && [ -d "$dir" ] || return 0
  for d in node_modules .venv venv vendor/bundle; do
    [ -d "$REPO/$d" ] || continue            # main checkout has it
    [ -e "$dir/$d" ] && continue             # worktree already has one (tracked) — don't clobber
    case "$d" in */*) mkdir -p "$dir/${d%/*}" 2>/dev/null || true ;; esac
    ln -s "$REPO/$d" "$dir/$d" 2>/dev/null || true
  done
}

# ---------------------------------------------------------------- prompts

# Write the (full) orchestrator-spawned worker operating manual ONCE to the session's .status dir.
# Workers read it from their launch prompt instead of carrying the whole thing inline. Generic
# across workers: <your-slug> = last segment of your branch; the per-worker task arrives inline.
ensure_worker_protocol() {
  mkdir -p "$STATUS"; printf '%s\n' "$REPO" > "$STATUS/repo"
  cat > "$STATUS/worker-protocol.md" <<EOF
# Worker operating manual (claude-fleet)

You are a worker the orchestrator spawned. Your identity + task are in your launch prompt; this file
is the HOW. Wherever it says <your-slug>, use your own slug (the last segment of your branch,
e.g. ${BR_PREFIX}/foo → "foo").

- FIRST read CLAUDE.md (repo root) + your project memory; follow its conventions, build/test commands,
  and rules. Don't re-explore or re-derive what's already documented there.
- Do your task now. PARALLELIZE: run INDEPENDENT pieces (different files, no ordering dependency) as
  parallel inline subagents (the Task/Agent tool — several in ONE message). You have ONE worktree, so
  NEVER run parallel agents that edit the SAME file — batch same-file changes into one pass. Verify.
- COMMIT to your branch (${BR_PREFIX}/<your-slug>) with SEPARATE PLAIN git commands: \`git add <files>\`
  then \`git commit -m "<what + why>"\` — never \`git -C <path> ...\`, never chain with \`&&\`. A CLEAR
  message: the orchestrator reads it to resolve any merge conflict. Do NOT push, checkout the default
  branch, or touch other branches — the orchestrator integrates your branch. Record durable gotchas
  (build quirks, "don't touch X") in CLAUDE.md or memory.
- REPORT with these EXACT commands:
    claude-fleet --status "<short note>"   — optional progress ping the orchestrator can see.
    claude-fleet --done                    — when fully finished AND committed (re-run after EACH task;
                                             the pane stays alive for more).
    claude-fleet --failed                  — if you genuinely cannot finish (blocked/broken); don't hang.
- STAY IN YOUR SCOPE (your files). FIX-FIRST, ESCALATE-THE-REST: actually fix every part you can reach —
  including anything the user assigns you DIRECTLY (a direct ask IS in scope, even a file outside the
  repo); don't diagnose-and-punt fixable work. Only escalate parts GENUINELY out of scope that you did
  NOT fix, and state plainly what you FIXED vs what you ESCALATED.
- Route out-of-scope work — never edit it, never emit paste-text — with ONLY these two channels:
    * claude-fleet --need "<what's needed + why + which files>"  — ask the orchestrator to schedule/
      spawn it. WORKS EVEN AFTER you've finished and been integrated (a post-merge --need surfaces as a
      follow-up). Recorded one by mistake? Retract with  claude-fleet --unneed.
    * write the brief to /tmp/cfleet_handoff_<your-slug>.txt, then
      claude-fleet --handoff "<sibling heading/slug>" /tmp/cfleet_handoff_<your-slug>.txt
      — hand it straight to the pane that owns those files (list siblings: claude-fleet --statuses).
    Doing both? Scope the --need to ONLY what you did NOT hand off, and say "ALREADY HANDED OFF to
    <slug>" for the rest (auto-linked — the orchestrator tracks it without re-dispatching).
- INCOMING WORK while you're busy (a new task typed into your pane, or --handoff'd from a sibling):
  NEVER drop, abandon, or interrupt what you're doing. Capture every one with TodoWrite, then —
  independent + non-blocking → parallel inline subagent, or queue and start when you finish; depends on
  your current work or touches the SAME files → queue and do it AFTER (same-file parallelism clobbers).
EOF
}

# the worker the orchestrator spawned with a concrete task (starts immediately)
spawn_worker_prompt() { # heading slug dir task
  local heading="$1" slug="$2" dir="$3" task="$4"
  ensure_worker_protocol
  cat <<EOF
You are a worker in a claude-fleet run — pane "${heading}" (slug "${slug}"), git worktree ${dir}, branch ${BR_PREFIX}/${slug} (cut from the orchestrator's latest integrated state).

Your task (assigned by the orchestrator):
${task}

READ ${STATUS}/worker-protocol.md NOW and follow it exactly — it is your operating manual (how to parallelize, commit, report with claude-fleet --done/--failed/--status, request --need, hand off, and handle incoming work). Wherever it says <your-slug>, use "${slug}".

Start now.
EOF
}

# the orchestrator: starts solo, reads project memory, decomposes goals, spawns workers, integrates + ships
spawn_orchestrator_prompt() { # dir dbr seed(0/1)
  local dir="$1" dbr="$2" seed="$3" seedstep="" newproj=""
  if [ "${CLAUDE_FLEET_NEW_PROJECT:-}" = 1 ]; then
    newproj="NO PROJECT FOLDER chosen yet. This is a brand-new project session.
FIRST: ask the user what they want to build (ONE short question). Wait for their answer.
Derive a short kebab-case folder name from their idea (e.g. 'recipe-box').
Write the user's FULL description to /tmp/cfleet_newproj_goal.txt (Write tool).
Then run EXACTLY:  claude-fleet --new-project <folder-name> /tmp/cfleet_newproj_goal.txt
Do NOT spawn any workers, do NOT create folders yourself, do NOT proceed until you've run --new-project. The app
will create ~/Developer/<folder-name>, relaunch you targeting it, and re-send the goal so you start building
automatically.

"
  fi
  if [ "$seed" = 1 ]; then
    seedstep="
STEP 0 — SEED PROJECT MEMORY (this project has no CLAUDE.md yet). Before any goal: briefly explore the repo and
write a concise CLAUDE.md at the repo root — build/run/test commands, the architecture map, key conventions, and
any hard rules a teammate would need. Keep it under ~150 lines. Commit it on ${dbr} (and 'git push origin
HEAD:${dbr}' if an 'origin' remote exists) so the workers you spawn inherit it. Then continue.
"
  fi
  cat <<EOF
${newproj}You are the ORCHESTRATOR for a claude-fleet run on the project at ${REPO}.
You are in ${dir}, a DETACHED checkout at ${dbr}'s tip. You start ALONE and create your own workers.

BIAS TO ACTION: do NOT over-deliberate before dispatching. For a simple single-area goal, skip heavy
decomposition — pick the cheaper tool (see below) and start IMMEDIATELY, then go to --watch. Reserve multi-phase
dependency planning for goals that genuinely need it. Spawning fast beats a perfect upfront plan; you can
always spawn more workers after.

NEVER ASK BEFORE ACTING — do NOT end a turn by asking me for permission or confirmation to spawn a worker or
make a fix. If you have diagnosed an issue, been handed a goal, or identified a fix, JUST DO IT: spawn the
worker (or launch a parallel Agent) and fix it. Phrases like "Want me to spawn a worker?", "Should I fix this?",
or "Let me know if you'd like me to proceed" are FORBIDDEN as a way to start work — they waste a turn; I brief
and redirect inside the panes, not by pre-approving dispatches. The ONLY time you ask a question is when it
genuinely blocks INTEGRATION (e.g. a merge-conflict intent you cannot resolve). Diagnosing a problem and then
stopping to ask whether to fix it is exactly the wrong move — diagnose AND dispatch the fix in the same turn.

WORKER vs PARALLEL AGENT — pick the cheaper tool, DEFAULT to the Agent for small jobs. A fleet --spawn-file worker
is EXPENSIVE to start (cuts a git worktree + boots a whole fresh claude pane = tens of seconds to minutes before
its first output). For a SMALL job — one or a few files, low risk, in-repo, no independent parallel threads needed
— do NOT spawn a fleet worker. Instead launch a parallel Agent (the Agent tool / a subagent) directly in your own
checkout, let it make + verify the change, then commit + integrate it yourself. That is the DEFAULT for small
single-area changes and is far faster. Reserve fleet --spawn-file workers for SUBSTANTIAL, multi-file, or genuinely
parallelizable work — independent threads that each need their own isolated worktree. When unsure and the change
is small: parallel Agent, not a worker. (This generalizes the trivial-self-discovered-fix exception below.)

MATCH EFFORT TO THE TASK — decide per dispatch, do NOT default everything to one level. When you spawn a fleet
worker, pass --effort to fit the job: 'low' for mechanical/trivial edits (rename, copy tweak, one-line fix, config
bump), 'medium' for small contained changes, 'high' for normal multi-file feature work (the default if you say
nothing), 'xhigh' ONLY for genuinely architectural / high-risk / deeply-cross-cutting work that needs maximum
reasoning. Low effort starts and finishes much faster, so under-spend on simple tasks and reserve xhigh for the
few that truly earn it. Judge each task on the go; a batch of workers may legitimately span several effort levels.

PROJECT MEMORY — read it first, keep it current:
- Read CLAUDE.md (repo root) if present, plus your auto-memory (MEMORY.md), to recover everything already known
  about this project. Do NOT re-explore what's documented there.
- After integrating work, record durable facts (build/test commands, architecture, gotchas, "don't touch X")
  into CLAUDE.md and/or memory. This is how the next session starts smart and we stop re-explaining / wasting tokens.
${seedstep}
TREAT EVERY GOAL I SEND AS A PERSISTENT TODO — track them with the TodoWrite tool, and NEVER drop one. When a NEW
goal arrives while work is already running, do NOT reflexively wait for the current one to finish. FIRST judge
whether the new goal is INDEPENDENT of everything in flight (different files/areas/products/repos, and it doesn't
need an in-flight worker's output):
  • INDEPENDENT → dispatch it RIGHT NOW, IN PARALLEL — spawn its worker(s) immediately alongside the running
    ones. Each worker is its own isolated worktree, so unrelated goals run concurrently. (E.g. "migrate the repo
    to another account" and "fix this UI bug" are unrelated → fire BOTH at once; don't make one wait on the other.)
  • DEPENDENT / overlapping (needs another goal's output, or touches the same files) → queue it and run it after
    the blocker integrates.
DEFAULT TO PARALLEL. Only serialize when there's a real dependency or file overlap. Never sit idle on a new goal
just because an earlier one is still draining — drain the running phase and dispatch the independent new goal in
the same breath.

HARD RULE — you COORDINATE, you NEVER implement. No feature/fix work in this pane. The only repo edits you make
here are: seeding/curating CLAUDE.md, and resolving MERGE CONFLICTS while integrating. Everything else is a
worker's job — even a one-line change → spawn a worker. This applies to the FIRST goal AND every follow-up.

EXCEPTION — trivial self-discovered fixes: for a TINY, fully in-scope, low-risk fix you discover yourself during
integration/verification (e.g. a one-line crash fix, a wrong resource ref), you MAY launch a lightweight parallel
Agent (the Agent tool / a subagent) to make + verify the fix directly, instead of a full --spawn-file worker,
PROVIDED: (a) the change is genuinely small and in-scope, (b) it does NOT touch files an in-flight worker is
currently editing (else queue it or fold it into that worker to avoid clobbering), and (c) it is built/verified
before integrating. Anything non-trivial, cross-cutting, or overlapping active worker files still goes through a
real fleet worker. NOTE: a fleet --spawn-file worker only commits inside a repo worktree, so for edits OUTSIDE the
repo (e.g. tooling/config files) you MUST use a parallel Agent, not a fleet worker.

SPAWN-FIRST — when my goal NAMES the threads/pages/products to work on (e.g. "we'll work on X, Y, and a new Z"),
spawn ONE long-lived worker per named thread RIGHT AWAY. Do NOT ask me for task specs, scope, product details, or
ordering before spawning — my workflow is to brief each worker DIRECTLY IN ITS PANE. Write a generic per-thread
brief (scope fence + project rules + "WAIT for the user to type the task in this pane, then implement → bust-cache
→ commit → claude-fleet --done"), fan all independent threads out in ONE phase, then go straight to --watch. Only
ask me a question when it actually blocks INTEGRATION (e.g. a merge-conflict intent) — never to START work.

For EACH goal I give you (now and every time after — repeat this whole cycle):
1. Decompose into subtasks, then map DEPENDENCIES: does any subtask need another's output — a function, type,
   API/contract, shared file, or scaffolding that another subtask creates? Group the subtasks into PHASES:
     • All independent (no shared output, no overlapping files) → ONE phase: fan them all out together.
     • Some build on a foundation → that foundation is PHASE 1; the subtasks that depend on it come in a LATER
       phase. Keep each phase as parallel as possible (everything with no unmet dependency runs together).
   Every worker you spawn is cut from your LATEST INTEGRATED STATE, so later-phase workers automatically build on
   the finished code from earlier phases. That's why ordering matters — and why workers never need to talk.
2. Run ONE phase at a time. For each subtask IN THE CURRENT PHASE: write its brief to /tmp/cfleet_<slug>.txt
   (Write tool), then:  claude-fleet --spawn-file "<short 1-3 word heading>" /tmp/cfleet_<slug>.txt
   PLAIN literal args only — NEVER \`claude-fleet --spawn "h" "\$(cat file)"\`, no \$(...), backticks, or pipes
   (command substitution can't be auto-approved and will pause for manual permission). --spawn-file avoids that.
3. DRAIN the current phase — run  claude-fleet --next  (blocks until a worker is ready). Then BATCH-INTEGRATE so
   you push + deploy ONCE for the whole batch, not once per worker (PLAIN git in ${dir}, no -C, no &&):
     claude-fleet --ready                  → EVERY slug ready right now.
     claude-fleet --conflicts              → any file touched by >1 ready branch. Merge THOSE branches one at a
                                           time and resolve carefully; merge the non-overlapping rest freely.
     For each ready slug S:  git merge --no-ff ${BR_PREFIX}/S
       On conflict, read BOTH sides first — git log --oneline ${dbr}..${BR_PREFIX}/S — then resolve preserving
       both intents. If one merge is too tangled, skip it, integrate the rest, handle the straggler on its own.
     Verify ONCE with the project's build/test (per CLAUDE.md); run the cache-bust step if CLAUDE.md defines one.
     ⚠️ SHIP THIS BATCH TO ${dbr} (DEFAULT — main advances automatically each batch, no waiting, no asking):
       git push origin HEAD:${dbr}   ONCE   (auto-deploys. If REFUSED/non-fast-forward: git fetch origin, re-merge
                                             origin/${dbr}, then retry — NEVER force-push ${dbr}.)
       claude-fleet --rebuild  ONCE          if THIS batch changed the app's OWN code (no-op otherwise).
     You MAY ALSO push your session integration branch as a harmless backup (diff-able, does NOT deploy):
       git push -f origin HEAD:${BR_PREFIX}/_integrated   ONCE   (force-update your own session integration branch)
     (OPT-OUT — if CLAUDE_FLEET_HOLD_MAIN=1 is exported, do NOT push ${dbr} this batch. Instead push ONLY to your
      session integration branch (git push -f origin HEAD:${BR_PREFIX}/_integrated), leave ${dbr} untouched so
      nothing deploys yet, and ship ${dbr} only at the FINAL SHIP (step 4). Set this when the user runs PARALLEL
      fleet/Claude sessions on this repo and wants ${dbr} to move only on one final reviewed cross-session merge.
      Legacy CLAUDE_FLEET_AUTOSHIP=1 is now the DEFAULT — accepted as a recognized no-op alias so old setups keep working.)
     claude-fleet --merged S               for EACH integrated slug.
   If --next prints  FAILED:S  → that worker gave up: do NOT merge it. Re-plan (respawn with a fresh brief, or
   drop it), then  claude-fleet --merged S  to clear it. (Optional: export CLAUDE_FLEET_NEXT_TIMEOUT=1800 so
   --next prints TIMEOUT instead of blocking forever on a silently-dead pane.  claude-fleet --statuses shows the
   live progress board anytime.)
   Then run  claude-fleet --needs  — a worker may record a prerequisite (a type/API/scaffold another task must
   produce) OR a follow-up REQUEST it can't do itself (cross-cutting work outside its scope fence, a shared-file
   change, "spawn a worker to do X"). Schedule it as a NEW subtask (this phase if independent, else the next).
   Entries tagged "(post-merge follow-up)" come from an ALREADY-INTEGRATED worker — still act on them: SPAWN a new
   worker (or --handoff to the sibling that owns those files), THEN  claude-fleet --need-clear <slug>  so it stops
   re-surfacing. Don't declare the goal done while an unhandled need remains.
   A need line tagged "[ALREADY HANDED OFF → X]" is ALREADY running in sibling X (the recording worker handed it off
   itself) — do NOT spawn or --handoff those parts again (you'd tell X the same thing twice); only schedule the parts
   NOT already handed off, then  claude-fleet --need-clear <slug>  once X re-signals --done.
   HANDOFF SAFETY:  claude-fleet --handoff <slug> <file>  RE-ARMS the target as tracked PENDING work even if it was
   already --merged — it clears the merged/done state and drops a .handoff marker, so --statuses shows it active and
   --next will WAIT for its re-signalled --done instead of reporting ALL DONE. So a handoff is ALWAYS followed by a
   tracked pending unit of work — never a silent loss. If --handoff exits NON-ZERO (unknown slug, or the pane's
   worktree is gone = dead), the work is NOT queued: SPAWN A FRESH worker for that brief instead. Never assume a
   failed handoff was delivered.
   "ALL DONE" (exit code 3) = the CURRENT phase is fully integrated. If more phases remain, go back to step 2 for
   the next phase — its workers will now see the finished foundation. Otherwise continue.
4. FINAL SHIP TO ${dbr} — under the DEFAULT (auto-ship) this is a NO-OP: ${dbr} is already current because you
   pushed it in step 3 after every batch, so there is nothing to do here. This step ONLY applies when
   CLAUDE_FLEET_HOLD_MAIN=1 held ${dbr} back — then do it when I explicitly say the work is done ("all work is
   done" / "ship it" / "merge to ${dbr}"). Steps (HOLD-MAIN case only):
     git fetch origin
     - List every integration/worker branch to fold in — THIS session AND any PARALLEL fleet/Claude sessions on
       this repo:  git branch -r | grep -E 'fleet|_integrated'  (include other sessions' ${BR_PREFIX%/*}/* and
       */_integrated branches, not just your own).
     - From a clean checkout of origin/${dbr}, merge those branches in one at a time. On a same-file conflict
       BETWEEN the two sessions, read BOTH sides (git log --oneline origin/${dbr}..<branch>) and resolve preserving
       both intents — this cross-session reconcile is the whole point of holding ${dbr} back.
     - Verify ONCE with the project's build/test (per CLAUDE.md); run the cache-bust step if CLAUDE.md defines one.
     git push origin HEAD:${dbr}  ONCE     ← the final (and, in hold-main mode, only) push to ${dbr} (auto-deploys).
                                           If REFUSED/non-fast-forward, fetch + re-merge origin/${dbr} and retry;
                                           never force-push ${dbr}.
     claude-fleet --rebuild  ONCE          if the merged work changed the app's OWN code (no-op otherwise).
     claude-fleet --merged S               for any slugs not already cleared.
5. Report a summary, write anything durable into CLAUDE.md/memory, then WAIT for my next goal. When it comes, do
   this whole cycle AGAIN with fresh workers — never do the work here yourself.
6. Between goals run  claude-fleet --watch  — FIRST  export CLAUDE_FLEET_WATCH_NEEDS=1  so it ALSO wakes on a
   worker's request, not just on re-signalled work. When it prints slug S, re-integrate it (step 3) and — by
   DEFAULT — push ${dbr} for that re-integration too (with CLAUDE_FLEET_HOLD_MAIN=1: instead push only to your
   session integration branch and hold ${dbr} for the FINAL SHIP, step 4). When it
   prints  NEED:S , a worker (often an already-integrated one) is asking for follow-up work: run  claude-fleet
   --needs , act on S's request (SPAWN a worker for it, or --handoff to the sibling that owns those files), then
   claude-fleet --need-clear S  so it stops re-firing. Either way, run  claude-fleet --watch  again afterward. If I
   type a new GOAL into this pane instead, stop watching and dispatch it via steps 1-3.

Wait for my goal.
EOF
}

# multi-repo orchestrator: coordinates N repos, spawns workers with --repo, integrates each repo's _main, ships atomically.
spawn_multi_orchestrator_prompt() { # coord_dir
  local coord="$1" r names="" IFS=:
  for r in $REPOS_LIST; do names="$names\n  - $(basename "$r")  ($r)  _main: $SESSIONS_DIR/$(basename "$r")-fleet${SESSION:+-$SESSION}/_main"; done
  cat <<EOF
You are the MULTI-REPO ORCHESTRATOR for a Gyftalala-mode claude-fleet run. You coordinate ONE task across SEVERAL
interconnected repos and ship them TOGETHER. You COORDINATE, you NEVER implement feature code yourself.

Repos you own (basename, path, and its integration checkout _main):$(printf '%b' "$names")

Your cwd is the coordination dir ${coord}. You can read any repo above directly to plan. Each repo has its OWN
isolated fleet: its own _main detached checkout, its own worker branches (${BR_PREFIX}/<slug>), its own origin/main.

HOW TO WORK A GOAL:
1. Decompose the task PER REPO. One feature usually touches several repos (e.g. a new server endpoint + the web
   client that calls it + the admin surface + the editor). Map cross-repo DEPENDENCIES: if repo B consumes a
   contract repo A produces (an API shape, a field), A is an EARLIER phase than B.
2. Spawn one worker per repo-slice, ALWAYS tagging the repo:
     write the brief to /tmp/cfleet_<slug>.txt (Write tool), then
     claude-fleet --spawn-file "<heading>" /tmp/cfleet_<slug>.txt --repo <repo-basename> [--effort <low|medium|high|xhigh>]
   The worker is cut from THAT repo's _main HEAD and works in that repo's worktree. PLAIN literal args only — no
   \$(...), backticks, or pipes. Fan out all independent slices in one phase; hold dependents for a later phase.
3. DRAIN: claude-fleet --next (blocks until a worker is ready). For each ready slug, integrate it INTO ITS REPO's
   _main — go to that repo's _main checkout and merge its branch with PLAIN git (no -C, no &&):
     claude-fleet --ready          → every ready slug (claude-fleet --statuses shows each slug's repo).
     For a ready slug S in repo R:  cd <R's _main>  then  git merge --no-ff ${BR_PREFIX}/S
       On conflict, read both sides (git log --oneline) and resolve preserving both intents.
     Verify R with its build/test (per R's CLAUDE.md). Then: claude-fleet --merged S
   FAILED:S from --next → do NOT merge; re-plan; claude-fleet --merged S to clear it.
   Then claude-fleet --needs — schedule any cross-repo prerequisite a worker recorded (often a contract repo B
   needs from repo A); claude-fleet --need-clear <slug> once handled.
   ALL DONE (exit 3) = current phase integrated in every repo → run step 4 (ship this phase). More phases → back
   to step 2 (later workers see the integrated foundation). Cross-repo contract passing is by BRIEF: when you integrate repo A's slice, put the
   resulting contract (endpoint shape, types) into repo B's worker brief — there are NO cross-repo git merges.
4. SHIP (DEFAULT — auto-ship each phase): as soon as a phase reaches ALL DONE (every repo integrated its workers
   for this phase), run EXACTLY:
     claude-fleet --ship-all
   Do NOT wait for the user to say "ship it" — ship each integrated phase automatically. (OPT-OUT: if
   CLAUDE_FLEET_HOLD_MAIN=1 is exported, do NOT auto-ship per phase; hold every repo's main and run
   claude-fleet --ship-all ONLY when the user says the whole task is done — "ship it" / "all done".)
   This is the hold-all gate: it confirms every repo integrated all its workers, dry-runs each repo's merge to
   origin/main, and pushes the repos to origin/main ONLY if EVERY repo passes the dry-run. If any repo is blocked it
   pushes NONE and tells you which repo + why — fix that repo (respawn/integrate), then re-run claude-fleet --ship-all.
   (Not a cross-repo transaction: if a push fails mid-sequence, earlier repos stay pushed — just re-run to finish.)
   NEVER push any repo's main yourself; --ship-all is the only path to origin/main.
5. Report a per-repo summary; record durable facts in each repo's CLAUDE.md/memory; then claude-fleet --watch and
   wait for the next goal. Repeat the whole cycle with fresh workers.

Wait for the user's goal.
EOF
}

# the INTEGRATOR: a dedicated pane (multi-repo, orchestrator OFF). The user tasks the worker panes directly; each worker
# commits + --done (never pushes). The Integrator does NOT implement, split tasks, or spawn workers — it runs an
# INCREMENTAL integration loop, landing each worker's change into the repos it touched as soon as it's safe.
spawn_integrator_prompt() { # coord_dir
  local coord="$1" r names="" IFS=:
  for r in $REPOS_LIST; do names="$names\n  - $(basename "$r")  ($r)  _main: $SESSIONS_DIR/$(basename "$r")-fleet${SESSION:+-$SESSION}/_main"; done
  cat <<EOF
You are the INTEGRATOR for a multi-repo Claude Fleet run (orchestrator OFF). The USER tasks the WORKER panes directly.
Each worker implements across whichever repos its task needs, COMMITS on its branch (${BR_PREFIX}/<slug>) in each changed
repo, then runs  claude-fleet --done . Workers do NOT push. YOU own ALL integration + pushing. You do NOT implement
feature code, you do NOT split tasks, and you do NOT spawn workers — you INTEGRATE what the workers hand you, one worker
at a time, as soon as each is safe.

Repos you integrate (basename, path, and its integration checkout _main):$(printf '%b' "$names")

Your cwd is the coordination dir ${coord}. Each repo above has its OWN integration checkout _main (a detached checkout at
that repo's default-branch tip) and its OWN worker branches ${BR_PREFIX}/<slug>. To land a worker in a repo you merge its
branch into that repo's _main, TEST it, then push _main → that repo's origin default branch.

INCREMENTAL LOOP — do NOT wait for all workers; land each worker the moment it's safe:
1. WAIT for the next worker:  export CLAUDE_FLEET_WATCH_NEEDS=1  then  claude-fleet --watch  (blocks; prints a ready
   slug S, or FAILED:S, or NEED:S).
2. See everything ready right now:  claude-fleet --ready  (several may have landed at once). Then  claude-fleet --conflicts
   — it lists any file touched by MORE THAN ONE unmerged worker (the overlap radar).
3. For each ready slug S, find WHICH repos it actually changed:  claude-fleet --touched S  (prints the basenames of the
   repos whose ${BR_PREFIX}/S branch is ahead of that repo's _main — the ONLY repos to touch for S).
4. NON-OVERLAPPING worker (S shares no file with any other unmerged worker per --conflicts) → LAND IT NOW, don't wait:
     For EACH repo R that  claude-fleet --touched S  printed:  cd <R's _main path above>  then  git merge --no-ff ${BR_PREFIX}/S
       On conflict, read BOTH sides first — git log --oneline HEAD..${BR_PREFIX}/S — then resolve preserving both intents.
     TEST-GATE every touched repo with its build/test (per R's CLAUDE.md; run any cache-bust/build step). If a repo
       FAILS: do NOT push it — print "✗ HELD S in <R> — <failure>" in this pane, leave S UN-merged (do NOT run
       claude-fleet --merged), and move on. NEVER push red.
     PUSH the per-worker changeset ATOMICALLY — ONLY the repos S touched, all-or-none:
       claude-fleet --ship <touched repo basenames…>     (dry-runs each, pushes all or none; resumable if a push fails)
     Then:  claude-fleet --merged S
5. OVERLAPPING workers (--conflicts shows S and a sibling touch the same file) → SERIALIZE just those: merge them into the
   shared repo's _main ONE AT A TIME. Read BOTH sides (git log --oneline HEAD..${BR_PREFIX}/<slug> for each) and resolve
   preserving BOTH intents. Test-gate, then  claude-fleet --ship <touched repos…>  for the group, then claude-fleet
   --merged for EACH. Merge the non-overlapping rest freely (step 4).
6. GENUINE DOUBT about intent (a conflict you cannot confidently resolve, or ambiguous overlapping requirements) → do NOT
   guess and do NOT push. PRINT a clear, specific question in THIS pane and WAIT for the user to answer, then resolve + ship.
7. FAILED:S → that worker gave up: do NOT merge it. Print "✗ FAILED:S — <the pane's reason>" and leave it for the user to
   re-task that pane. (If you want --watch to stop counting it,  claude-fleet --merged S  clears it.)
8. NEED:S → a worker recorded a prerequisite/follow-up ( claude-fleet --needs  shows it). You do NOT spawn workers —
   relay it to the user (which pane, what it needs); once it's handled  claude-fleet --need-clear S  so it stops re-firing.
9. Go back to step 1 ( claude-fleet --watch ). A worker the user RE-TASKS re-runs --done → --watch wakes again and you
   re-integrate its new commit the same way.

Wait for the workers.
EOF
}

# ---------------------------------------------------------------- subcommands

# emit JSON for the solo orchestrator pane; creates the _main detached worktree and detects whether to seed memory
cmd_orchestrator() {
  if [ "${CLAUDE_FLEET_MULTI:-}" = 1 ]; then
    [ -n "$REPOS_LIST" ] || die "multi-repo orchestrator needs CLAUDE_FLEET_REPOS"
    assert_unique_repo_basenames                  # fail loud on duplicate basenames (would collide onto one fleet)
    reset_state                                   # coordination STATUS (CLAUDE_FLEET_STATUS_DIR); manifest seeded
    local r odir IFS=:
    local -a member_fleets=()                      # collected member fleet paths for the coord's gc `members` marker
    for r in $REPOS_LIST; do                      # create each repo's own _main integration checkout
      [ -d "$r/.git" ] || die "not a git repository: $r"
      select_repo "$r"; fetch_origin
      odir="$FLEET/_main"
      if [ ! -d "$odir" ]; then
        git -C "$REPO" worktree add --detach "$odir" "origin/$DBR" >&2 2>/dev/null \
          || git -C "$REPO" worktree add --detach "$odir" "$DBR" >&2
      fi
      link_shared_dirs "$odir"
      # Give each member fleet the SAME .status/repo marker a single-repo session has, so cmd_gc_all can vet it
      # via gc_one_session's G0-G4 (instead of skipping it as "no repo marker"). Points at the REAL member repo.
      mkdir -p "$FLEET/.status"
      printf '%s\n' "$REPO" > "$FLEET/.status/repo"
      member_fleets+=("$FLEET")
    done
    local coord; coord="$(dirname "$STATUS")"     # the coordination dir (parent of .status)
    mkdir -p "$coord"
    # Flag the coord as a coordination dir for gc: one absolute member-fleet path per line. gc_one_coord reaps the
    # coord only once EVERY listed member is gone (so an unmerged member kept by G3 also keeps the coord). This marker
    # is what cmd_gc_all routes on (BEFORE the .status/repo check), so the coord's own repo-marker (= coord, non-git)
    # is harmless. `member_fleets` is guaranteed non-empty here (REPOS_LIST was validated above).
    printf '%s\n' "${member_fleets[@]}" > "$coord/.status/members"
    printf '[{"role":"orchestrator","slug":"orchestrator","heading":"Orchestrator","dir":%s,"prompt":%s}]\n' \
      "$(json_str "$coord")" "$(json_str "$(spawn_multi_orchestrator_prompt "$coord")")"
    return 0
  fi
  # — single-repo path, unchanged —
  [ -d "$REPO/.git" ] || die "not a git repository: $REPO"
  fetch_origin
  set_default_branch
  reset_state
  local odir="$FLEET/_main"
  if [ ! -d "$odir" ]; then
    git -C "$REPO" worktree add --detach "$odir" "origin/$DBR" >&2 2>/dev/null \
      || git -C "$REPO" worktree add --detach "$odir" "$DBR" >&2
  fi
  link_shared_dirs "$odir"
  local seed=0
  [ -f "$odir/CLAUDE.md" ] || [ -f "$odir/.claude/CLAUDE.md" ] || seed=1
  printf '[{"role":"orchestrator","slug":"orchestrator","heading":"Orchestrator","dir":%s,"prompt":%s}]\n' \
    "$(json_str "$odir")" "$(json_str "$(spawn_orchestrator_prompt "$odir" "$DBR" "$seed")")"
}

# Multi-repo ship: dry-run EVERY repo, then push them. NOT a true cross-repo transaction — git has no such thing —
# so this is a BEST-EFFORT hold-all with a resumable tail, not strict all-or-nothing. Phase 1 dry-runs every
# CLAUDE_FLEET_REPOS repo's integrated _main HEAD against origin/<DBR>; if ANY repo can't land cleanly (no
# integration checkout, empty HEAD, or a non-fast-forward against its remote tip) we push NOTHING and exit non-zero
# with every blocker listed — this is the real "hold all if any can't go" guarantee. Phase 2 runs only when all
# repos are feasible: it pushes each repo in REPOS_LIST order (re-fetching + re-confirming ff right before each
# push). The residual gap: if a push fails mid-sequence (auth drop, remote moved between dry-run and push, network),
# the repos already pushed STAY pushed. That partial state is reported with the exact landed list and is RESUMABLE —
# re-running --ship-all re-dry-runs (already-landed repos are now ff no-ops) and finishes the rest.
# FEASIBILITY: a repo is shippable iff its remote default branch is ABSENT (first push) OR its remote tip is an
# ANCESTOR of the integrated _main HEAD (a clean fast-forward: `git merge-base --is-ancestor <tip> <head>`). Any
# divergence (the remote moved out from under us, e.g. an external push) is a non-ff → NOT feasible → held. This
# exit-code check is robust and needs no `merge-tree --write-tree` (and thus no git >=2.38).
# Push a GIVEN SET of repos' integrated _main → origin/<DBR>. Hold-all: dry-run every repo first; if ANY can't ff
# cleanly, push NOTHING. Then push each (re-confirming ff right before each). Best-effort tail (a mid-sequence failure
# leaves earlier repos pushed) — RESUMABLE. Shared by --ship-all (all CLAUDE_FLEET_REPOS) and --ship (a subset — the
# Integrator's per-worker atomic changeset). $1 = the label used in messages (e.g. --ship-all / --ship); rest = repo refs.
ship_repos() { # <label> <repo-ref...>
  local label="$1"; shift
  [ "$#" -gt 0 ] || die "$label needs at least one repo"
  local r odir head target tip blockers=""
  # Phase 1 — DRY RUN each repo. Block if a repo has no _main, an empty HEAD, or its HEAD can't fast-forward origin/DBR.
  for r in "$@"; do
    select_repo "$r"; odir="$FLEET/_main"
    if [ ! -d "$odir" ]; then blockers="$blockers\n  - $(basename "$r"): no integration checkout ($odir) — nothing integrated"; continue; fi
    fetch_origin
    head="$(git -C "$odir" rev-parse --verify --quiet HEAD || true)"
    [ -n "$head" ] || { blockers="$blockers\n  - $(basename "$r"): empty _main HEAD"; continue; }
    if has_origin; then target="origin/$DBR"; else target="$DBR"; fi
    tip="$(git -C "$odir" rev-parse --verify --quiet "$target" || true)"
    if [ -z "$tip" ]; then
      :                                                              # remote/default branch absent → first push, fine
    elif git -C "$odir" merge-base --is-ancestor "$tip" "$head" 2>/dev/null; then
      :                                                              # fast-forward: integrated HEAD already contains the target tip
    else
      blockers="$blockers\n  - $(basename "$r"): integrated HEAD ${head:0:8} does NOT fast-forward $target ${tip:0:8} (remote moved; reconcile in $odir: git merge $target)"
    fi
  done
  if [ -n "$blockers" ]; then
    printf 'claude-fleet: %s HELD ALL repos — nothing pushed. Blocked:%b\n' "$label" "$blockers" >&2
    exit 1
  fi
  # Phase 2 — push each repo. Re-confirm fast-forward right before each push; report partial landings on failure.
  local landed=""
  for r in "$@"; do
    select_repo "$r"; odir="$FLEET/_main"
    gh_align   # align gh's active account to THIS repo's origin owner (e.g. gyftalala) so osxkeychain can push it
    has_origin || { printf 'claude-fleet: %s has no origin — skipped push (integrated locally on _main).\n' "$(basename "$r")" >&2; continue; }
    git -C "$odir" fetch --prune origin >&2 2>/dev/null || true
    head="$(git -C "$odir" rev-parse --verify --quiet HEAD || true)"
    tip="$(git -C "$odir" rev-parse --verify --quiet "origin/$DBR" || true)"
    if [ -n "$tip" ] && ! git -C "$odir" merge-base --is-ancestor "$tip" "$head" 2>/dev/null; then
      printf 'claude-fleet: %s aborted before pushing %s — origin/%s moved since the dry run (non-ff). Already pushed: %s. Re-run %s.\n' "$label" "$(basename "$r")" "$DBR" "${landed:-none}" "$label" >&2
      exit 1
    fi
    if ! git -C "$odir" push origin "HEAD:$DBR" >&2; then
      printf 'claude-fleet: %s push FAILED on %s after pushing: %s. State is PARTIAL — re-run %s to finish the rest.\n' "$label" "$(basename "$r")" "${landed:-none}" "$label" >&2
      exit 1
    fi
    landed="$landed $(basename "$r")"
  done
  printf 'claude-fleet: %s pushed to their default branch:%s\n' "$label" "${landed}"
}

cmd_ship_all() {
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--ship-all is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--ship-all needs CLAUDE_FLEET_REPOS"
  local IFS=:
  # shellcheck disable=SC2086 — deliberate colon word-split of REPOS_LIST into positional repo refs
  set -- $REPOS_LIST
  ship_repos "--ship-all" "$@"
}

# --ship: like --ship-all but only the GIVEN repos (basename or path). The Integrator uses this to push exactly the
# repos ONE worker changed — a per-worker atomic changeset that lands WITHOUT waiting for the other workers.
cmd_ship() { # <repo-ref...>
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--ship is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--ship needs CLAUDE_FLEET_REPOS"
  [ "$#" -gt 0 ] || die "--ship needs at least one repo (basename or path)"
  ship_repos "--ship" "$@"
}

# Multi-repo: print the repos a worker slug actually CHANGED — those whose fleet/s<sid>/<slug> branch has commit(s)
# ahead of that repo's integrated _main HEAD. One basename per line (empty if it touched nothing). The Integrator scopes
# its per-worker atomic push (--ship) to exactly these. Idempotent: after the Integrator merges S into a repo's _main,
# that repo drops out (branch no longer ahead), so a re-run reflects only what's still unlanded.
cmd_touched() { # <slug>
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--touched is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--touched needs CLAUDE_FLEET_REPOS"
  local slug="${1:-}"; [ -n "$slug" ] || die "--touched needs a slug"
  local r odir head n branch="$BR_PREFIX/$slug" IFS=:
  for r in $REPOS_LIST; do
    [ -n "$r" ] || continue
    select_repo "$r"; odir="$FLEET/_main"
    [ -d "$odir" ] || continue
    git -C "$odir" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null 2>&1 || continue
    head="$(git -C "$odir" rev-parse --verify --quiet HEAD || true)"
    [ -n "$head" ] || continue
    n="$(git -C "$odir" rev-list --count "HEAD..refs/heads/$branch" 2>/dev/null || echo 0)"
    if [ "${n:-0}" -gt 0 ]; then printf '%s\n' "$(basename "$REPO")"; fi
  done
}

# spawn a worker for a subtask; writes a .spawn marker the app turns into a pane.
# Reads optional EFFORT (low|medium|high|xhigh, already validated by the caller): when set, the marker JSON
# gains an "effort" field so the app can launch the worker at that reasoning effort; when empty the marker is
# emitted exactly as before (no extra field).
_do_spawn() { # <heading> <task>   (reads EFFORT from the environment/caller)
  local heading="$1" task="$2" effort="${EFFORT:-}"
  [ -n "$heading" ] || die "spawn needs <heading> <task>"
  [ -d "$STATUS" ] || die "no active session"
  local slug base k=2 branch dir
  slug="$(slugify "$heading")"; [ -n "$slug" ] || slug="worker"; base="$slug"
  # Multi-repo: cut this worker's worktree from the requested repo's fleet (FLEET re-points to <repo>-fleet-<sid>).
  # STATUS stays the shared coordination dir, so the manifest/markers remain on the one board. Single-repo path
  # (no --repo) leaves FLEET/REPO exactly as-is → original behavior. Re-point BEFORE the uniqueness loop so the
  # directory half ([ -d "$FLEET/$slug" ]) inspects the correct fleet dir, not the orchestrator's ambient one.
  local target_repo=""
  if [ -n "${SPAWN_REPO:-}" ]; then select_repo "$SPAWN_REPO"; target_repo="$REPO"; fi
  while [ -d "$FLEET/$slug" ] || grep -qx "$slug" "$MANIFEST" 2>/dev/null; do slug="$base-$k"; k=$((k + 1)); done
  branch="$BR_PREFIX/$slug"; dir="$FLEET/$slug"
  # cut from the orchestrator's LATEST INTEGRATED STATE (_main HEAD) so dependency-phased workers build on the
  # finished foundation from earlier phases — works with or without a remote. Fall back to origin/DBR then DBR.
  local base; base="$(git -C "$FLEET/_main" rev-parse --verify --quiet HEAD 2>/dev/null || true)"
  [ -n "$base" ] || base="origin/$DBR"
  git -C "$REPO" worktree add -b "$branch" "$dir" "$base" >/dev/null 2>&1 \
    || git -C "$REPO" worktree add -b "$branch" "$dir" "$DBR" >&2
  link_shared_dirs "$dir"
  printf '%s\n' "$slug" >> "$MANIFEST"
  rm -f "$STATUS/$slug.done" "$STATUS/$slug.merged" "$STATUS/$slug.closed" "$STATUS/$slug.working"   # fresh worker: clear any stale closed/done/merged/working state if the slug is reused
  local effort_field=""
  [ -n "$effort" ] && effort_field=",\"effort\":$(json_str "$effort")"
  local repo_field=""
  if [ -n "$target_repo" ]; then
    repo_field=",\"repo\":$(json_str "$target_repo")"
    printf '%s\n' "$target_repo" > "$STATUS/$slug.repo"   # sidecar: lets --ready/--ship-all/--handoff find this slug's repo
  fi
  # Write the (multi-KB) marker atomically: tmp + mv, so the app's fs.watch never reads a truncated JSON blob and
  # drops the worker pane (a single `>` of a large prompt is not guaranteed to be one write()).
  printf '{"slug":%s,"heading":%s,"dir":%s,"prompt":%s%s%s}' \
    "$(json_str "$slug")" "$(json_str "$heading")" "$(json_str "$dir")" \
    "$(json_str "$(spawn_worker_prompt "$heading" "$slug" "$dir" "$task")")" "$effort_field" "$repo_field" > "$STATUS/$slug.spawn.tmp"
  mv -f "$STATUS/$slug.spawn.tmp" "$STATUS/$slug.spawn"
  printf 'Spawned worker "%s" (%s).\n' "$heading" "$slug"
}

# validate + capture an optional "--effort LEVEL" flag from a spawn subcommand's args, in a position-tolerant way
# (it may trail the positional args, e.g. --spawn "H" "task" --effort high). Echoes the remaining (non-effort)
# args one per line so the caller can re-read them; sets EFFORT for _do_spawn to pick up.
EFFORT=""
SPAWN_REPO=""
parse_effort_args() { # <args...> -> sets EFFORT + SPAWN_REPO, fills ARGS_REST with the rest
  EFFORT=""; SPAWN_REPO=""
  local -a rest=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --effort)
        [ -n "${2:-}" ] || die "--effort needs a level (low|medium|high|xhigh)"
        case "$2" in low|medium|high|xhigh) EFFORT="$2" ;; *) die "invalid --effort '$2' (use low|medium|high|xhigh)" ;; esac
        shift 2 ;;
      --repo)
        [ -n "${2:-}" ] || die "--repo needs a repo name or path"
        SPAWN_REPO="$2"; shift 2 ;;
      *) rest+=("$1"); shift ;;
    esac
  done
  ARGS_REST=("${rest[@]+"${rest[@]}"}")
}
cmd_spawn() {                                                              # inline task (short) [+ optional --effort]
  parse_effort_args "$@"; set -- ${ARGS_REST[@]+"${ARGS_REST[@]}"}
  local heading="${1:-}"; shift || true; _do_spawn "$heading" "$*"
}
# read the (long/quote-heavy) brief from a FILE so the spawn command stays static and auto-approves
# (claude-fleet --spawn "h" "$(cat file)" contains command substitution and would prompt every time).
cmd_spawn_file() { # <heading> <task-file> [--effort LEVEL]
  parse_effort_args "$@"; set -- ${ARGS_REST[@]+"${ARGS_REST[@]}"}
  local heading="${1:-}" path="${2:-}"
  [ -n "$path" ] || die "--spawn-file needs <heading> <task-file>"
  [ -f "$path" ] || die "task file not found: $path"
  _do_spawn "$heading" "$(cat "$path")"
}

# route a requirement DIRECTLY to a sibling pane (by product name OR slug): writes <slug>.task, which the app
# types into that pane and submits — so a pane that realizes work belongs to a sibling HANDS IT OFF and the
# sibling RUNS it, instead of printing paste-text for the human to copy. Brief read from a FILE so the command
# stays static (no command-substitution permission prompt). Works in both modes.
#
# A handoff must NEVER silently no-op. If the target was already --merged (or --done/--failed), copying a .task
# alone left ALL its done/merged state intact, so --next skipped it and reported ALL DONE — the handed-off work was
# untracked and lost (observed live 2026-06-15). So --handoff now RE-ARMS the target as tracked PENDING work:
# clears its merged/done/failed state and drops a .handoff marker. --statuses then shows it active, --next WAITS
# for its re-signalled --done (no premature ALL DONE), and its eventual --done makes it --ready for integration.
# If the slug is unknown or its worktree is gone (pane dead), it FAILS LOUDLY (non-zero) telling the orchestrator
# to spawn a FRESH worker — never a silent success that does nothing.
cmd_handoff() { # <target-pane> <task-file>
  local target="$1" path="$2"
  [ -n "$target" ] && [ -n "$path" ] || die "--handoff needs <target-pane> <task-file>"
  [ -f "$path" ] || die "task file not found: $path"
  [ -d "$STATUS" ] || die "no active fleet"
  local slug; slug="$(slugify "$target")"
  grep -qx "$slug" "$MANIFEST" 2>/dev/null \
    || die "no sibling pane '$target' (slug '$slug') in this fleet — handoff CANNOT deliver; spawn a FRESH worker for this brief instead. (panes: claude-fleet --statuses)"
  # If the slug was spawned into a specific repo, point FLEET at that repo's fleet so the worktree-liveness check
  # (and any path references) resolve correctly in multi-repo runs. Single-repo: no .repo sidecar → unchanged.
  if [ -f "$STATUS/$slug.repo" ]; then select_repo "$(cat "$STATUS/$slug.repo")"; fi
  # Liveness guard: the pane's worktree must still exist. If it was removed (e.g. --clean'd), the pane is dead and
  # a handoff would vanish — fail loudly so the orchestrator spawns fresh rather than trusting a lost handoff.
  [ -d "$FLEET/$slug" ] || die "pane '$target' (slug '$slug') has no worktree at $FLEET/$slug — it is DEAD; handoff CANNOT deliver, spawn a FRESH worker for this brief instead."
  # Liveness guard 2: the pane's WINDOW may have been CLOSED while its worktree lingers on disk. The app drops a
  # <slug>.closed marker when the pane's pty dies (user closed it / claude exited), so the worktree-exists check above
  # is not enough — a handoff would write a .task no live claude ever reads (the "black hole"). Fail loudly.
  [ -f "$STATUS/$slug.closed" ] && die "pane '$target' (slug '$slug') was CLOSED — its claude is no longer running; handoff CANNOT deliver, spawn a FRESH worker for this brief instead."
  # Atomic delivery (tmp + mv): the app types `.task` into the pane and reads `.handoff` for --next tracking; a plain
  # `cp` is non-atomic, so a watcher/reader can see a truncated brief. Write `.handoff` BEFORE re-arming so --next
  # never observes a re-armed-but-untracked state.
  cp "$path" "$STATUS/$slug.handoff.tmp" && mv -f "$STATUS/$slug.handoff.tmp" "$STATUS/$slug.handoff"   # marker: outstanding handed-off unit of work
  cp "$path" "$STATUS/$slug.task.tmp"    && mv -f "$STATUS/$slug.task.tmp"    "$STATUS/$slug.task"      # the app types this into the pane (unchanged contract)
  rm -f "$STATUS/$slug.merged" "$STATUS/$slug.done" "$STATUS/$slug.failed"   # RE-ARM: tracked, pending, not ALL DONE
  # DEDUP: if this handoff came FROM a worker worktree, link it to that worker so a
  # co-recorded --need covering the same work isn't ALSO re-dispatched by the
  # orchestrator (observed double-tell 2026-06-15). --needs surfaces this link as
  # "[ALREADY HANDED OFF → <slug>]" so the orchestrator tracks without re-telling.
  local src_branch src_slug
  src_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  case "$src_branch" in
    "$BR_PREFIX"/*) src_slug="${src_branch#"$BR_PREFIX"/}"; printf '%s\n' "$slug" >> "$STATUS/$src_slug.handoff_to" ;;
  esac
  printf 'Handed off to "%s" (%s) — RE-ARMED as tracked pending work; it will run this now, then re-signal --done.\n' "$target" "$slug"
}

cmd_done() {
  [ -d "$STATUS" ] || die "no active fleet"
  local branch slug
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || die "not in a git repo"
  case "$branch" in "$BR_PREFIX"/*) slug="${branch#"$BR_PREFIX"/}" ;; *) die "branch '$branch' is not a $BR_PREFIX/* worker" ;; esac
  rm -f "$STATUS/$slug.merged" "$STATUS/$slug.failed" "$STATUS/$slug.handoff" "$STATUS/$slug.working"   # re-arm; supersedes prior FAILED; clears any outstanding handoff; clears the app's live .working bridge (explicit --done supersedes it)
  # P3: auto-record files this worker touched so the orchestrator can detect cross-branch overlaps (--conflicts)
  set_default_branch
  local cbase
  cbase="$(git merge-base HEAD "origin/$DBR" 2>/dev/null || git merge-base HEAD "$DBR" 2>/dev/null || true)"
  [ -n "$cbase" ] && git diff --name-only "$cbase" HEAD > "$STATUS/$slug.claims" 2>/dev/null || true
  touch "$STATUS/$slug.done"
  printf 'Marked "%s" done. Orchestrator will integrate it.\n' "$slug"
}

cmd_next() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s pending failed all_merged
  local timeout="${CLAUDE_FLEET_NEXT_TIMEOUT:-0}" start=$SECONDS   # seconds; 0 = block forever (default, back-compat)
  while true; do
    pending=""; failed=""; all_merged=1
    while IFS= read -r s; do
      [ -n "$s" ] || continue
      # A CLOSED pane (window closed / pty died; app dropped <slug>.closed) is DEAD — its claude can no longer signal
      # --done. Treat it like merged: skip it so it neither blocks --next nor keeps ALL DONE from firing. (Don't report
      # it as work; the orchestrator should spawn fresh if it still needs that thread.)
      [ -f "$STATUS/$s.closed" ] && continue
      # An outstanding .handoff keeps a worker tracked as ACTIVE even if a .merged marker lingers — never report
      # ALL DONE while handed-off work hasn't re-signalled --done. (A re-armed handoff has .merged removed anyway;
      # this is belt-and-suspenders so ALL DONE can never fire over a pending handoff.)
      # A re-activated worker: an already-integrated (.merged/.done) pane that picked up a NEW in-pane task is RUNNING
      # again with no fresh .done yet — the app bridges this with a live `<slug>.working` marker. Count it as ACTIVE so
      # --next keeps BLOCKING (never reports ALL DONE while a worker is mid-task), but it has nothing to integrate yet,
      # so don't surface it as `pending`. A later --done clears .working and supersedes this (and clears .merged here too).
      if [ -f "$STATUS/$s.working" ] && [ ! -f "$STATUS/$s.done" ] && [ ! -f "$STATUS/$s.failed" ]; then all_merged=0; continue; fi
      [ -f "$STATUS/$s.merged" ] && [ ! -f "$STATUS/$s.handoff" ] && continue
      all_merged=0
      if [ -f "$STATUS/$s.failed" ]; then failed="$s"; break; fi
      if [ -f "$STATUS/$s.done" ]; then pending="$s"; break; fi
    done < "$MANIFEST"
    if [ -n "$pending" ]; then printf '%s\n' "$pending"; exit 0; fi
    if [ -n "$failed" ]; then printf 'FAILED:%s\n' "$failed"; exit 0; fi
    if [ "$all_merged" -eq 1 ]; then
      # Post-integration: every worker is merged. Auto-gc THIS session, heavily guarded (G1-G4 in gc_one_session) —
      # it can never remove the live session or unmerged work; a guard failure just prints SKIP. Then report ALL DONE.
      gc_auto_current
      echo "ALL DONE"; exit 3
    fi
    if [ "$timeout" -gt 0 ] && [ "$((SECONDS - start))" -ge "$timeout" ]; then echo "TIMEOUT"; exit 5; fi
    sleep 0.7
  done
}

# like --next but NEVER exits on all-merged: the orchestrator stays blocked, waiting for a follow-up
# (a worker that re-runs claude-fleet --done after the initial batch was already integrated)
cmd_watch() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s watch_needs="${CLAUDE_FLEET_WATCH_NEEDS:-0}" NEED_GRACE="${CLAUDE_FLEET_NEED_GRACE:-8}"
  while true; do
    while IFS= read -r s; do
      [ -n "$s" ] || continue
      # A CLOSED pane is DEAD — skip it so it neither wakes the watcher (stale .done/.failed) nor blocks. (Mirrors --next.)
      [ -f "$STATUS/$s.closed" ] && continue
      # A recorded need wakes the watcher even from an already-integrated worker
      # (a post-merge follow-up request). OPT-IN via CLAUDE_FLEET_WATCH_NEEDS=1 so
      # it doesn't change the legacy contract for orchestrators that only parse
      # slug / FAILED:slug. Orchestrator must --need-clear after handling, else the
      # same NEED re-fires on the next --watch.
      # SETTLE WINDOW: a .need must persist for >=NEED_GRACE seconds before it wakes the
      # orchestrator, so a need recorded then retracted (--unneed / --need-clear) within the
      # window never fires (prevents acting on a mis-sent need). Tunable via CLAUDE_FLEET_NEED_GRACE.
      # A long-standing need just fires on the next loop pass — no lasting delay.
      if [ "$watch_needs" = "1" ] && [ -f "$STATUS/$s.need" ]; then
        nmt="$(stat -f %m "$STATUS/$s.need" 2>/dev/null || stat -c %Y "$STATUS/$s.need" 2>/dev/null || echo 0)"
        if [ "$(( $(date +%s) - nmt ))" -ge "$NEED_GRACE" ]; then printf 'NEED:%s\n' "$s"; exit 0; fi
      fi
      # A re-activated worker (.working, no fresh .done) is RUNNING again — stay blocked waiting for its eventual --done;
      # don't let a lingering stale .merged make us skip it as integrated. (--watch never fires ALL DONE anyway; this
      # just keeps the active-pane bookkeeping consistent with --next.)
      if [ -f "$STATUS/$s.working" ] && [ ! -f "$STATUS/$s.done" ] && [ ! -f "$STATUS/$s.failed" ]; then continue; fi
      # outstanding .handoff = still active even if a stale .merged lingers (see --next)
      [ -f "$STATUS/$s.merged" ] && [ ! -f "$STATUS/$s.handoff" ] && continue
      if [ -f "$STATUS/$s.failed" ]; then printf 'FAILED:%s\n' "$s"; exit 0; fi
      if [ -f "$STATUS/$s.done" ]; then printf '%s\n' "$s"; exit 0; fi
    done < "$MANIFEST"
    sleep 0.7
  done
}

# Integrate a worker. Clears its transient live .status, but PRESERVES any .need —
# a recorded need is a request to the orchestrator that can outlive the worker's own
# merge (cross-cutting follow-up work). Clear needs explicitly with --need-clear.
cmd_merged() {
  [ -n "${1:-}" ] || die "--merged needs a slug"; [ -d "$STATUS" ] || die "no active fleet"
  touch "$STATUS/$1.merged"; rm -f "$STATUS/$1.status" "$STATUS/$1.handoff" "$STATUS/$1.working"; printf 'Marked "%s" integrated.\n' "$1"
  # Multi-repo: this slug may belong to a member repo other than the orchestrator's ambient one. Point FLEET/REPO at
  # the slug's repo (via its .repo sidecar) BEFORE advancing, so advance_canonical_branch persists the RIGHT repo's
  # integrated _main — not the ambient repo's. (cmd_handoff does the same; single-repo: no sidecar → unchanged.)
  [ -f "$STATUS/$1.repo" ] && select_repo "$(cat "$STATUS/$1.repo")"
  # DATA-LOSS FIX: when there is no origin to push to, the orchestrator integrated this slug into its DETACHED `_main`
  # HEAD only. Persist that integrated state onto the canonical branch ref NOW (ff-only) so the commits are reachable
  # from refs/heads/$DBR and survive teardown. With an origin, this is a no-op (the push path is unchanged). If it
  # CANNOT safely advance (non-ff / dirty checkout), it prints a LOUD REFUSED line and we `die` so the orchestrator
  # stops and resolves rather than continuing toward a teardown that would strand the commits.
  advance_canonical_branch || die "could not advance canonical $DBR to the integrated state (see REFUSED line above) — resolve before continuing; do NOT --clean or the integrated commits will be lost."
}

# print every slug ready to integrate right now (.done, not yet merged, not failed). The orchestrator drains the
# whole batch in ONE merge+verify+push instead of one deploy per worker. Read-only; never blocks.
cmd_ready() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    [ -f "$STATUS/$s.merged" ] && continue
    [ -f "$STATUS/$s.failed" ] && continue
    [ -f "$STATUS/$s.done" ] && printf '%s\n' "$s"
  done < "$MANIFEST"
}

# (inside a worker worktree) signal this worker CANNOT finish; --next/--watch surface FAILED:<slug> so the
# orchestrator re-plans (respawn or drop) instead of blocking forever. Cleared when the orchestrator runs --merged.
cmd_failed() {
  [ -d "$STATUS" ] || die "no active fleet"
  local branch slug
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || die "not in a git repo"
  case "$branch" in "$BR_PREFIX"/*) slug="${branch#"$BR_PREFIX"/}" ;; *) die "branch '$branch' is not a $BR_PREFIX/* worker" ;; esac
  rm -f "$STATUS/$slug.done" "$STATUS/$slug.handoff"   # a failed worker surfaces via FAILED:<slug>; no outstanding handoff left to track
  touch "$STATUS/$slug.failed"
  printf 'Marked "%s" FAILED. Orchestrator will re-plan instead of waiting.\n' "$slug"
}

# P3: report files claimed (touched) by more than one not-yet-merged worker — pre-merge collision radar.
# Prints "<path>: slugA slugB ..." per overlapping file; prints nothing when there are no overlaps.
cmd_conflicts() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s f
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    [ -f "$STATUS/$s.merged" ] && continue
    [ -f "$STATUS/$s.claims" ] || continue
    while IFS= read -r f; do [ -n "$f" ] && printf '%s\t%s\n' "$f" "$s"; done < "$STATUS/$s.claims"
  done < "$MANIFEST" | sort | awk -F'\t' '
    $1!=pf { if (n>1) print pf": "slugs; pf=$1; slugs=""; n=0 }
    { slugs=slugs (slugs==""?"":" ") $2; n++ }
    END { if (n>1) print pf": "slugs }'
}

# P5: (inside a worker worktree) record a prerequisite this task needs another task to produce first.
cmd_need() {
  [ -d "$STATUS" ] || die "no active fleet"
  [ -n "${1:-}" ] || die "--need needs a description"
  local branch slug
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || die "not in a git repo"
  case "$branch" in "$BR_PREFIX"/*) slug="${branch#"$BR_PREFIX"/}" ;; *) die "branch '$branch' is not a $BR_PREFIX/* worker" ;; esac
  printf '%s\n' "$1" > "$STATUS/$slug.need"
  printf 'Recorded need for "%s": %s\n' "$slug" "$1"
}

# P5: list recorded prerequisites/requests the orchestrator should schedule.
# Surfaces needs from ALL workers, INCLUDING already-integrated (.merged) ones — a
# --need recorded after a worker's own work shipped is a follow-up request (cross-
# cutting work it can't do under its scope fence, a shared-file change, "spawn a
# worker to do X") the orchestrator must still act on. Entries from merged workers
# are tagged so the orchestrator has context. Cleared explicitly via --need-clear.
cmd_needs() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s tag hoff
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    [ -f "$STATUS/$s.need" ] || continue
    [ -f "$STATUS/$s.merged" ] && tag=" (post-merge follow-up)" || tag=""
    hoff=""
    [ -f "$STATUS/$s.handoff_to" ] && hoff=" [ALREADY HANDED OFF → $(paste -sd, "$STATUS/$s.handoff_to" 2>/dev/null) — those parts are RUNNING in that sibling; TRACK ONLY, do NOT re-dispatch/re-handoff; --need-clear once it re-signals --done]"
    printf '%s%s%s: %s\n' "$s" "$tag" "$hoff" "$(cat "$STATUS/$s.need")"
  done < "$MANIFEST"
}

# P7: (orchestrator) mark a worker's recorded need handled so it stops surfacing in
# --needs / --watch. Run after you've scheduled it (spawned a worker / handed off)
# or decided it's moot. Needs now PERSIST across --merged on purpose, so this is the
# only thing that clears them.
cmd_need_clear() {
  [ -n "${1:-}" ] || die "--need-clear needs a slug"
  [ -d "$STATUS" ] || die "no active fleet"
  rm -f "$STATUS/$1.need" "$STATUS/$1.handoff_to"
  printf 'Cleared need for "%s".\n' "$1"
}

# (inside a worker worktree) RETRACT a need this worker recorded by mistake — the worker-facing
# counterpart to the orchestrator's --need-clear. Resolves its own slug from the branch. Run this
# promptly after a mis-sent --need so the settle window in --watch absorbs it before it fires.
cmd_unneed() {
  [ -d "$STATUS" ] || die "no active fleet"
  local branch slug
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || die "not in a git repo"
  case "$branch" in "$BR_PREFIX"/*) slug="${branch#"$BR_PREFIX"/}" ;; *) die "branch '$branch' is not a $BR_PREFIX/* worker" ;; esac
  rm -f "$STATUS/$slug.need" "$STATUS/$slug.handoff_to"
  printf 'Retracted need for "%s".\n' "$slug"
}

# P6: (inside a worker worktree) post a one-line live progress note.
cmd_status() {
  [ -d "$STATUS" ] || die "no active fleet"
  [ -n "${1:-}" ] || die "--status needs a message"
  local branch slug
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)" || die "not in a git repo"
  case "$branch" in "$BR_PREFIX"/*) slug="${branch#"$BR_PREFIX"/}" ;; *) die "branch '$branch' is not a $BR_PREFIX/* worker" ;; esac
  printf '%s\n' "$1" > "$STATUS/$slug.status"
  printf 'Status for "%s": %s\n' "$slug" "$1"
}

# P6: the live progress board — one line per unmerged worker (slug: status).
cmd_statuses() {
  [ -f "$MANIFEST" ] || die "no manifest — is a fleet running?"
  local s st
  while IFS= read -r s; do
    [ -n "$s" ] || continue
    # A CLOSED pane is DEAD (window closed / pty died) — surface it as such so the orchestrator spawns fresh instead of
    # waiting on or handing off to it. Shown even if a stale .merged lingers.
    if [ -f "$STATUS/$s.closed" ]; then printf '%s: %s\n' "$s" "(closed)"; continue; fi
    # show a re-armed handoff target as active even if a stale .merged lingers (see --next)
    # a re-activated worker (live .working from the app, no fresh --done) is also active even if a stale .merged lingers
    [ -f "$STATUS/$s.merged" ] && [ ! -f "$STATUS/$s.handoff" ] && [ ! -f "$STATUS/$s.working" ] && continue
    # Prefer an explicit --status line. Else, if the app dropped a live `.working` marker (a re-activated already-integrated
    # worker running a new in-pane task with no fresh --done yet), surface it as (working) so the orchestrator sees it's
    # still busy. Then handoff, then the default.
    if [ -f "$STATUS/$s.status" ]; then st="$(cat "$STATUS/$s.status")"; elif [ -f "$STATUS/$s.working" ]; then st="(working)"; elif [ -f "$STATUS/$s.handoff" ]; then st="(handed-off work pending)"; else st="(no status yet)"; fi
    printf '%s: %s\n' "$s" "$st"
  done < "$MANIFEST"
}

cmd_clean() {
  [ -d "$REPO/.git" ] || die "not a git repository: $REPO"
  # SAFETY GUARD 1 — never clean the session you're running INSIDE. Worker/orchestrator panes live under $FLEET
  # ($FLEET/_main, $FLEET/<slug>). Cleaning $FLEET from in there self-deletes the LIVE session out from under the
  # running panes (this WIPED a live session on 2026-06-18: a worker's verify ran --clean with its own SESSION env,
  # rm -rf'ing its own fleet dir incl. _main). Refuse even under CLAUDE_FLEET_FORCE — a force-clean of your own
  # live session is never what you want; legit cleans (from the app, or another session's dir) are unaffected.
  case "$PWD/" in
    "$FLEET"/*) die "refusing --clean: cwd ($PWD) is INSIDE the session being cleaned ($FLEET). This would delete the live session you're running in. Run --clean from OUTSIDE the fleet dir (the app does), never from a worker/orchestrator pane." ;;
  esac
  # SAFETY GUARD 2 — sanity-check the target really is a session fleet dir before any rm -rf. Guards against a
  # mis-set REPO/SESSION pointing $FLEET at the repo, $HOME, or /. Must be a namespaced "<repo>-fleet-<session>".
  [ -n "$SESSION" ] || die "refusing --clean: CLAUDE_FLEET_SESSION is empty — won't clean an unnamespaced fleet dir ($FLEET)."
  case "$FLEET" in
    "$HOME"|"$HOME"/|/|"$REPO") die "refusing --clean: computed fleet dir ($FLEET) is not a session worktree dir." ;;
    *-fleet-*) : ;;
    *) die "refusing --clean: computed fleet dir ($FLEET) does not look like a '<repo>-fleet-<session>' dir." ;;
  esac
  # SAFETY GUARD 3 (DATA-LOSS) — never prune a worktree/branch that holds commits NOT reachable from canonical $DBR.
  # Tearing those down strands the commits (no ref points at them → dangling → GC), which is exactly how a shipped
  # rewrite vanished from main on 2026-06-18. We FIRST try to persist any integrated `_main` state onto $DBR
  # (no-op if origin exists or already in sync), THEN refuse to clean if anything under this fleet — the orchestrator
  # `_main` HEAD, any worker worktree HEAD, or any fleet/* branch tip — is still ahead of $DBR. Override with
  # CLAUDE_FLEET_FORCE_ORPHAN=1 ONLY when you have deliberately decided to discard that work.
  set_default_branch
  advance_canonical_branch || true   # best-effort: persist integrated _main onto $DBR before we inspect reachability
  if [ "${CLAUDE_FLEET_FORCE_ORPHAN:-}" != 1 ]; then
    local dbr_sha unreachable="" wt head br
    dbr_sha="$(git -C "$REPO" rev-parse --verify --quiet "refs/heads/$DBR" 2>/dev/null || true)"
    if [ -n "$dbr_sha" ]; then
      # worktree HEADs (orchestrator _main + each worker dir)
      while IFS= read -r wt; do
        case "$wt" in
          "$FLEET"/*)
            head="$(git -C "$wt" rev-parse --verify --quiet HEAD 2>/dev/null || true)"
            [ -n "$head" ] || continue
            git -C "$REPO" merge-base --is-ancestor "$head" "$dbr_sha" 2>/dev/null \
              || unreachable="$unreachable  $wt (HEAD ${head:0:12})\n"
            ;;
        esac
      done < <(git -C "$REPO" worktree list --porcelain | awk '/^worktree /{print $2}')
      # fleet/* branch tips (a worker may have committed but never been integrated)
      while IFS= read -r br; do
        [ -n "$br" ] || continue
        head="$(git -C "$REPO" rev-parse --verify --quiet "$br" 2>/dev/null || true)"
        [ -n "$head" ] || continue
        git -C "$REPO" merge-base --is-ancestor "$head" "$dbr_sha" 2>/dev/null \
          || unreachable="$unreachable  $br (tip ${head:0:12})\n"
      done < <(git -C "$REPO" for-each-ref --format='%(refname:short)' "refs/heads/$BR_PREFIX")
    else
      unreachable="  (canonical $DBR ref does not exist — refusing to prune anything before main is established)\n"
    fi
    if [ -n "$unreachable" ]; then
      printf 'claude-fleet: REFUSED --clean — the following hold commits NOT reachable from canonical %s:\n' "$DBR" >&2
      printf '%b' "$unreachable" >&2
      die "integrate/advance these into $DBR first (the orchestrator should --merged them), or set CLAUDE_FLEET_FORCE_ORPHAN=1 to DISCARD this work intentionally. Refusing to strand commits."
    fi
  fi
  if [ "${CLAUDE_FLEET_FORCE:-}" != 1 ]; then
    printf 'Remove this session'\''s fleet worktrees + %s/* branches? [y/N] ' "$BR_PREFIX"
    read -r ans || ans=""   # non-interactive/EOF: don't let set -e abort on read's non-zero before the prompt resolves
    [ "$ans" = y ] || [ "$ans" = Y ] || { echo "aborted"; exit 0; }
  fi
  git -C "$REPO" worktree list --porcelain | awk '/^worktree /{print $2}' | while IFS= read -r wt; do
    case "$wt" in "$FLEET"/*) git -C "$REPO" worktree remove --force "$wt" || true ;; esac
  done
  git -C "$REPO" worktree prune
  git -C "$REPO" for-each-ref --format='%(refname:short)' "refs/heads/$BR_PREFIX" | while IFS= read -r br; do
    [ -n "$br" ] && git -C "$REPO" branch -D "$br" || true
  done
  rm -rf "$FLEET"
  echo "fleet cleaned."
}

# ---------------------------------------------------------------- gc (guarded auto-clean of finished sessions)
#
# G0 LIVENESS probe (read-only). Returns 0 (LIVE) if ANY running process has a cwd at/under $1. Used by both
# gc_one_session (member/single-repo sessions) and gc_one_coord (coordination dirs) so the probe lives in ONE place.
# FAIL-SAFE: returns LIVE (0) when lsof is missing so a bare `if gc_is_live` treats the unverifiable case as live →
# the caller SKIPs. (A caller that wants a DISTINCT "lsof unavailable" message tests `command -v lsof` separately,
# as gc_one_session/gc_one_coord do, before calling this.)
gc_is_live() { # <dir>
  local dir="$1" _cwd
  command -v lsof >/dev/null 2>&1 || return 0
  while IFS= read -r _cwd; do
    case "$_cwd" in n*) _cwd="${_cwd#n}" ;; *) continue ;; esac
    case "$_cwd" in "$dir"|"$dir"/*) return 0 ;; esac
  done < <(lsof -nP -d cwd -F n 2>/dev/null)
  return 1
}

# --gc garbage-collects FULLY-INTEGRATED fleet session FOLDERS for the configured CLAUDE_FLEET_REPO. A session's
# worktree folder is removed ONLY IF all four guards pass; any failing guard => SKIP with a reason, NEVER forced.
#   G1. Not the session you are currently inside (cwd not under the candidate fleet dir; sid != $CLAUDE_FLEET_SESSION).
#   G2. The parent/original repo folder exists and is a git repo.
#   G3. EVERY branch of that session (fleet/s<sid>/*) is FULLY merged into the repo's default branch.
#   G4. No worktree in that session has uncommitted changes.
# Deletion is folder-only-safe: `git worktree remove --force` each registered worktree under the session dir, then
# `rm -rf` the session dir, then `git worktree prune`. Fully-merged branches are left in place (folders are the goal).
#
# gc_one_session inspects + (if all guards pass) removes ONE session. Args: <fleet-dir> <sid>. It NEVER reads the
# global $FLEET/$SESSION/$BR_PREFIX — it is given an explicit target so the auto-hook and the manual sweep share it.
# Prints exactly one line: "REMOVED <dir>" or "SKIP <dir> (<reason>)". Returns 0 on remove, 1 on skip (non-fatal).
gc_one_session() { # <fleet-dir> <sid>
  local gdir="$1" sid="$2" gbr_prefix br_glob fbase
  gbr_prefix="fleet${sid:+/s$sid}"; br_glob="refs/heads/$gbr_prefix"
  fbase="$SESSIONS_DIR/$(basename "$REPO")"   # expected session-dir prefix for THIS repo, under SESSIONS_DIR

  # Hard path assertions BEFORE anything destructive: the target must be the "<repo>-fleet[-<sid>]" dir for THIS repo
  # under SESSIONS_DIR — never $HOME, /, the repo, or the sessions root itself. (Defense-in-depth for the rm -rf below.)
  case "$gdir" in
    ""|"$HOME"|"$HOME"/|/|"$REPO"|"$SESSIONS_DIR"|"$SESSIONS_DIR"/) printf 'SKIP %s (not a session worktree dir)\n' "$gdir"; return 1 ;;
    "$fbase"-fleet|"$fbase"-fleet-*) : ;;   # must be the fleet dir for THIS repo under SESSIONS_DIR
    *) printf 'SKIP %s (does not look like a session dir for %s)\n' "$gdir" "$REPO"; return 1 ;;
  esac
  [ -d "$gdir" ] || { printf 'SKIP %s (no such directory)\n' "$gdir"; return 1; }

  # EXCLUDE — caller-supplied skip list (colon-separated absolute dirs in CLAUDE_FLEET_GC_EXCLUDE). The app passes the
  # sessions it is about to RESTORE so a startup sweep never reaps a folder being reopened. Belt-and-suspenders with G0
  # (a restored pane becomes LIVE once its pty holds a cwd inside; the exclude covers the spawn-race window before that).
  case ":${CLAUDE_FLEET_GC_EXCLUDE:-}:" in
    *":$gdir:"*) printf 'SKIP %s (excluded by caller)\n' "$gdir"; return 1 ;;
  esac

  # G0 — LIVENESS guard. A session is LIVE if ANY running process has a current working directory at or under the
  # candidate fleet dir (panes run `claude` with cwd inside $gdir/_main, $gdir/<slug>, etc.). This protects ANY live
  # session — including a DIFFERENT concurrently-running app window on the same repo — not just the current process
  # (G1 only covers self). FAIL-SAFE: if lsof is unavailable we CANNOT confirm the session is dead, so we SKIP.
  if ! command -v lsof >/dev/null 2>&1; then
    printf 'SKIP %s (cannot verify liveness — lsof unavailable; remove manually if the session is closed)\n' "$gdir"; return 1
  fi
  # Liveness probe is shared via gc_is_live (read-only); same `lsof -nP -d cwd` semantics, message unchanged.
  if gc_is_live "$gdir"; then
    printf 'SKIP %s (session appears LIVE — a process has its cwd inside it; refusing to delete a running session)\n' "$gdir"; return 1
  fi

  # G1 — never gc the session you are currently INSIDE (reuse/extend cmd_clean's self-wipe guard). Two checks:
  #   (a) cwd is under the candidate fleet dir; (b) this process's own CLAUDE_FLEET_SESSION matches this sid.
  case "$PWD/" in "$gdir"/*) printf 'SKIP %s (cwd is INSIDE this session — refusing self-wipe)\n' "$gdir"; return 1 ;; esac
  if [ -n "${CLAUDE_FLEET_SESSION:-}" ] && [ "${CLAUDE_FLEET_SESSION}" = "$sid" ]; then
    printf 'SKIP %s (this is the live session you are running — refusing self-wipe)\n' "$gdir"; return 1
  fi

  # G2 — parent/original repo must exist and be a git repo. If it's gone, CANCEL (we cannot check merge state safely).
  [ -d "$REPO/.git" ] || { printf 'SKIP %s (parent repo %s missing — cannot verify merge state)\n' "$gdir" "$REPO"; return 1; }

  set_default_branch
  # NOTE: unlike cmd_clean we do NOT advance_canonical_branch here. GC is a passive sweep (runs on startup + the
  # --next ALL-DONE hook); auto-advancing would MOVE a no-origin repo's live `main` (potentially a --no-ff merge
  # commit) as a side effect of cleanup — surprising. The reachability guard (G3.5) below already PREVENTS the
  # data loss by HOLDING any folder whose _main/worktree HEAD isn't reachable from $DBR. To actually reap such a
  # folder, advance via the normal flow (claude-fleet --merged / --rebuild / manual --clean, which DO advance).
  local dbr_sha
  dbr_sha="$(git -C "$REPO" rev-parse --verify --quiet "refs/heads/$DBR" 2>/dev/null || true)"
  [ -n "$dbr_sha" ] || { printf 'SKIP %s (canonical %s ref does not exist — not safe to gc)\n' "$gdir" "$DBR"; return 1; }

  # G3 — every fleet/s<sid>/* branch must be FULLY merged into $DBR (0 commits ahead). If ANY has unmerged work, SKIP.
  local br ahead
  while IFS= read -r br; do
    [ -n "$br" ] || continue
    ahead="$(git -C "$REPO" rev-list --count "$DBR..$br" 2>/dev/null || echo 1)"
    [ "$ahead" = 0 ] || { printf 'SKIP %s (branch %s has unmerged work — %s commit(s) not in %s)\n' "$gdir" "$br" "$ahead" "$DBR"; return 1; }
  done < <(git -C "$REPO" for-each-ref --format='%(refname:short)' "$br_glob" 2>/dev/null)

  # G3.5 — REACHABILITY (the 2026-06-18 data-loss class). G3 only covers fleet/* BRANCH tips; the orchestrator's
  # DETACHED `_main` HEAD (and any worker worktree HEAD) can hold commits not on any branch. If such a commit isn't
  # reachable from $DBR, `git worktree remove` + `rm -rf` below would strand it. SKIP if ANY worktree HEAD under
  # $gdir is not an ancestor of $DBR. (cmd_clean does the same check; gc_one_session previously did not.)
  local rwt rhead
  while IFS= read -r rwt; do
    [ -n "$rwt" ] || continue
    case "$rwt" in
      "$gdir"/*)
        rhead="$(git -C "$rwt" rev-parse --verify --quiet HEAD 2>/dev/null || true)"
        [ -n "$rhead" ] || continue
        git -C "$REPO" merge-base --is-ancestor "$rhead" "$dbr_sha" 2>/dev/null \
          || { printf 'SKIP %s (worktree %s HEAD %s not reachable from %s — integrate/advance first; refusing to strand commits)\n' "$gdir" "$rwt" "${rhead:0:12}" "$DBR"; return 1; }
        ;;
    esac
  done < <(git -C "$REPO" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2}')

  # G4 — no registered worktree UNDER this session dir may have uncommitted changes (real git status, not filtered:
  # for gc we want a strict empty tree). Enumerate worktrees the same way cmd_clean does, scoped to this session dir.
  local wt
  while IFS= read -r wt; do
    [ -n "$wt" ] || continue
    case "$wt" in
      "$gdir"/*)
        if [ -d "$wt" ] && [ -n "$(git -C "$wt" status --porcelain 2>/dev/null)" ]; then
          printf 'SKIP %s (worktree %s has uncommitted changes)\n' "$gdir" "$wt"; return 1
        fi
        ;;
    esac
  done < <(git -C "$REPO" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2}')

  # All guards passed — folder-only-safe teardown. Remove each registered worktree under this session dir, rm the
  # dir, prune. (Branches are fully merged so they may remain; removing folders is the goal.)
  while IFS= read -r wt; do
    [ -n "$wt" ] || continue
    case "$wt" in "$gdir"/*) git -C "$REPO" worktree remove --force "$wt" >/dev/null 2>&1 || true ;; esac
  done < <(git -C "$REPO" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2}')
  rm -rf "$gdir"
  git -C "$REPO" worktree prune >/dev/null 2>&1 || true
  printf 'REMOVED %s\n' "$gdir"
  return 0
}

# gc_one_coord reaps a Gyftalala COORDINATION dir (flagged by .status/members). Unlike a member fleet it has NO git,
# branches, or worktrees — it holds only .status — so G2/G3/G4 do not apply; the only deletion is `rm -rf $gdir`.
# Guards: hard path-assert (under $SESSIONS_DIR + the *-multi-fleet[-<sid>] shape, never root/$HOME/sessions-root),
# EXCLUDE list, G0 liveness (lsof; SKIP if unverifiable), G1 self (cwd inside / CLAUDE_FLEET_SESSION == sid), and
# MEMBERS-GONE: every member fleet listed in .status/members must already be removed. Because the coord is reaped
# only AFTER its members, a member with unmerged work (kept by gc_one_session's G3) keeps the coord too.
# Prints exactly one "REMOVED <dir>" / "SKIP <dir> (<reason>)" line. Returns 0 on remove, 1 on skip (non-fatal).
gc_one_coord() { # <coord-dir> <sid>
  local gdir="$1" sid="$2" m left=0
  # Hard path assertions BEFORE the rm -rf (defense-in-depth): under SESSIONS_DIR, matching the coord naming, never
  # $HOME, /, or the sessions root itself.
  case "$gdir" in
    ""|"$HOME"|"$HOME"/|/|"$SESSIONS_DIR"|"$SESSIONS_DIR"/) printf 'SKIP %s (not a coord dir)\n' "$gdir"; return 1 ;;
  esac
  case "$gdir" in
    "$SESSIONS_DIR"/*-multi-fleet|"$SESSIONS_DIR"/*-multi-fleet-*) : ;;
    *) printf 'SKIP %s (does not look like a coordination dir)\n' "$gdir"; return 1 ;;
  esac
  [ -f "$gdir/.status/members" ] || { printf 'SKIP %s (no members marker)\n' "$gdir"; return 1; }

  # EXCLUDE — caller-supplied skip list (the app passes the dirs it is about to RESTORE).
  case ":${CLAUDE_FLEET_GC_EXCLUDE:-}:" in *":$gdir:"*) printf 'SKIP %s (excluded by caller)\n' "$gdir"; return 1 ;; esac

  # G0 — liveness. FAIL-SAFE: lsof unavailable → cannot confirm dead → SKIP.
  if ! command -v lsof >/dev/null 2>&1; then
    printf 'SKIP %s (cannot verify liveness — lsof unavailable)\n' "$gdir"; return 1
  fi
  if gc_is_live "$gdir"; then printf 'SKIP %s (coordination dir appears LIVE)\n' "$gdir"; return 1; fi

  # G1 — never gc the session you are currently INSIDE (cwd under it, or CLAUDE_FLEET_SESSION matches this sid).
  case "$PWD/" in "$gdir"/*) printf 'SKIP %s (cwd is INSIDE this session — refusing self-wipe)\n' "$gdir"; return 1 ;; esac
  if [ -n "${CLAUDE_FLEET_SESSION:-}" ] && [ "${CLAUDE_FLEET_SESSION}" = "$sid" ]; then
    printf 'SKIP %s (this is the live session you are running — refusing self-wipe)\n' "$gdir"; return 1
  fi

  # MEMBERS-GONE — do not reap the coord while ANY member fleet folder still exists (it may hold unmerged work that
  # gc_one_session's G3 is keeping). Reaped only once every listed member is off disk.
  # Fail-safe: `|| [ -n "$m" ]` processes a final line lacking a trailing newline; empty/unparseable marker → HOLD.
  local seen=0
  while IFS= read -r m || [ -n "$m" ]; do
    [ -n "$m" ] || continue
    seen=1
    [ -d "$m" ] && { left=1; break; }
  done < "$gdir/.status/members"
  if [ "$seen" = 0 ]; then
    printf 'SKIP %s (members marker empty/unreadable — cannot verify; refusing to reap)\n' "$gdir"; return 1
  fi
  [ "$left" = 0 ] || { printf 'SKIP %s (member fleet(s) still present — reaping coord only after members)\n' "$gdir"; return 1; }

  rm -rf "$gdir"
  printf 'REMOVED %s\n' "$gdir"
  return 0
}

# Auto-hook: after a session is fully integrated, gc THIS session (same G1-G4 guards). Called from the
# post-integration ALL DONE path. It can NEVER remove the live session (G1) or unmerged work (G3); a guard failure
# just prints SKIP and is non-fatal. OPT-OUT with CLAUDE_FLEET_NO_AUTOGC=1.
gc_auto_current() {
  [ "${CLAUDE_FLEET_NO_AUTOGC:-}" = 1 ] && return 0
  [ -d "$REPO/.git" ] || return 0
  # Sweep ALL sibling sessions of this repo (NOT just the current one). The orchestrator runs --next from INSIDE
  # $FLEET, so we must NOT bail when cwd is inside $FLEET — that would prevent reaping fully-merged, clean, NON-LIVE
  # SIBLING sessions. The current session is never deleted: it is LIVE (G0 — our own panes hold cwds inside it) and
  # also matches G1 ($PWD inside $gdir / $CLAUDE_FLEET_SESSION == sid). Any OTHER live session is protected by G0.
  gc_sweep_repo >&2 || true
}

# gc_sweep_repo: iterate every <repo>-fleet[-*] session folder for the configured repo, deriving the sid per folder,
# and call gc_one_session on each (which removes only those passing G0-G4). Shared by --gc and the auto hook.
# Returns 0 if at least one candidate folder was found, 1 if none existed.
gc_sweep_repo() {
  local base gdir sid found=0
  base="$(basename "$REPO")"
  shopt -s nullglob
  for gdir in "$SESSIONS_DIR/$base"-fleet "$SESSIONS_DIR/$base"-fleet-*; do
    [ -d "$gdir" ] || continue
    found=1
    # derive sid: "<base>-fleet-<sid>" -> <sid>; "<base>-fleet" -> "" (unnamespaced)
    case "$gdir" in
      "$SESSIONS_DIR/$base"-fleet-*) sid="${gdir##*-fleet-}" ;;
      *) sid="" ;;
    esac
    gc_one_session "$gdir" "$sid" || true
  done
  shopt -u nullglob
  [ "$found" = 1 ]
}

# --gc: sweep every <repo>-fleet[-*] session folder for the configured repo, gc'ing only those passing G0-G4.
cmd_gc() {
  [ -d "$REPO/.git" ] || die "not a git repository: $REPO"
  local base; base="$(basename "$REPO")"
  gc_sweep_repo || echo "claude-fleet --gc: no $base-fleet* session folders to sweep."
}

# --gc-all: sweep EVERY <repo>-fleet[-<sid>] session folder under a ROOT dir (default: the parent of CLAUDE_FLEET_REPO,
# i.e. ~/Developer), deriving the parent repo + sid from each folder name and gc'ing each via gc_one_session (G0-G4 +
# exclude guards). Unlike --gc (one configured repo), this reaps finished/orphaned sessions across ALL repos — so a
# folder left behind by an app quit/crash (no --next ALL DONE moment) gets reclaimed on the next app launch. Each
# folder runs in a SUBSHELL with REPO overridden so $REPO/set_default_branch resolve per-folder and never leak.
# Root override: arg $1 or CLAUDE_FLEET_GC_ROOT. Honors CLAUDE_FLEET_GC_EXCLUDE (colon-separated dirs to skip).
cmd_gc_all() { # [root]
  local root="${1:-${CLAUDE_FLEET_GC_ROOT:-$SESSIONS_DIR}}"
  [ -d "$root" ] || { echo "claude-fleet --gc-all: no sessions dir ($root)."; return 0; }
  local gdir repo sid found=0
  shopt -s nullglob
  for gdir in "$root"/*-fleet "$root"/*-fleet-*; do
    [ -d "$gdir" ] || continue
    found=1
    # derive sid from the folder name: "<base>-fleet-<sid>" -> <sid> ; "<base>-fleet" -> "" .
    # Real fleet sids are NUMERIC (the app's nextSid). Requiring that rejects non-fleet dirs that merely contain
    # "-fleet-" in their name without relying on the git-repo check below.
    case "$gdir" in
      *-fleet-*) sid="${gdir##*-fleet-}"; case "$sid" in ''|*[!0-9]*) continue ;; esac ;;
      *-fleet)   sid="" ;;
      *) continue ;;
    esac
    # Gyftalala COORDINATION dirs are flagged by .status/members (no git/branches/worktrees). Route them to the
    # coord-specific reaper BEFORE the repo-marker check below — the coord ALSO has a .status/repo (= the coord path,
    # non-git) that would otherwise SKIP as an invalid marker. Member fleets have .status/repo (not members) and keep
    # flowing to gc_one_session. Run in a subshell + || true so a SKIP never aborts the set -e sweep.
    if [ -f "$gdir/.status/members" ]; then ( gc_one_coord "$gdir" "$sid" ) || true; continue; fi
    # The repo is NOT beside the session dir anymore — read it from the session's .status/repo marker (written at
    # init). Without a valid marker we cannot verify merge state safely, so SKIP (never rm a folder we can't vet).
    repo=""; [ -f "$gdir/.status/repo" ] && repo="$(head -n1 "$gdir/.status/repo" 2>/dev/null || true)"
    if [ -z "$repo" ] || [ ! -d "$repo/.git" ]; then printf 'SKIP %s (no/invalid repo marker)\n' "$gdir"; continue; fi
    # gc_one_session returns 1 on any guard SKIP (non-fatal); guard with || true so set -e doesn't abort the sweep.
    ( REPO="$repo"; gc_one_session "$gdir" "$sid" ) || true
  done
  shopt -u nullglob
  [ "$found" = 1 ] || echo "claude-fleet --gc-all: no *-fleet* session folders under $root."
}

# Rebuild + reinstall the project's app from the LATEST INTEGRATED STATE, ONCE per batch (a full app build is
# expensive — the orchestrator calls this after the post-batch push, only when the batch changed app code).
# Project-agnostic: runs the project's configured rebuild command and streams its output live. Resolution order:
#   1. $CLAUDE_FLEET_REBUILD_CMD       — a shell command string (highest precedence; run via `bash -c`)
#   2. <build-dir>/.claude-fleet/rebuild — a script committed in the repo (run via `bash`, no +x needed)
# No rebuild command configured => NO-OP (exit 0); never fail a project that doesn't define one (e.g. a web app
# that auto-deploys on push). <build-dir> = the orchestrator's _main worktree (the pushed/integrated tip) if it
# exists, else $REPO. Set CLAUDE_FLEET_REBUILD_DRYRUN=1 to print the resolved command without running it.
cmd_rebuild() {
  local bdir="$FLEET/_main"
  [ -d "$bdir" ] || bdir="$REPO"
  local cmd="" kind=""
  if [ -n "${CLAUDE_FLEET_REBUILD_CMD:-}" ]; then
    cmd="$CLAUDE_FLEET_REBUILD_CMD"; kind="\$CLAUDE_FLEET_REBUILD_CMD"
  elif [ -f "$bdir/.claude-fleet/rebuild" ]; then
    cmd="$bdir/.claude-fleet/rebuild"; kind="$cmd"
  fi
  if [ -z "$cmd" ]; then
    printf 'claude-fleet --rebuild: no rebuild command configured (no $CLAUDE_FLEET_REBUILD_CMD, no %s/.claude-fleet/rebuild) — skipping.\n' "$bdir"
    exit 0
  fi
  if [ "${CLAUDE_FLEET_REBUILD_DRYRUN:-}" = 1 ]; then
    printf 'claude-fleet --rebuild: DRYRUN — would run [%s] in %s\n' "$cmd" "$bdir"; exit 0
  fi
  printf 'claude-fleet --rebuild: rebuilding app in %s via %s\n' "$bdir" "$kind" >&2
  if [ -n "${CLAUDE_FLEET_REBUILD_CMD:-}" ]; then
    ( cd "$bdir" && bash -c "$cmd" )
  else
    ( cd "$bdir" && CLAUDE_FLEET_BUILD_DIR="$bdir" bash "$cmd" )
  fi
  printf 'claude-fleet --rebuild: done.\n' >&2
}

# New-project bootstrap (run by the SCRATCH orchestrator under CLAUDE_FLEET_NEW_PROJECT=1). The scratch
# orchestrator asks the user what to build, derives a folder name, writes the goal to GOALFILE, then calls this.
# We drop an ATOMIC marker file the app watches for ($STATUS/project.retarget) carrying the chosen <name> and the
# goal text; the app then creates ~/Developer/<name>, relaunches the orchestrator targeting it, and re-sends the
# goal so building starts automatically.
# LOCKED interop (the app parses these EXACT strings): marker path "$STATUS/project.retarget"; JSON keys "name"
# and "goal". Do NOT rename them.
cmd_new_project() { # <name> <goalfile>
  local name="${1:-}" goalfile="${2:-}"
  [ -n "$name" ] || die "--new-project needs <name> <goalfile>"
  [ -n "$goalfile" ] || die "--new-project needs <name> <goalfile>"
  [ -r "$goalfile" ] || die "goal file not readable: $goalfile"
  [ -d "$STATUS" ] || die "no active session (no $STATUS) — --new-project must run inside a scratch fleet session"
  # sanitize/validate the folder name: kebab-ish, no slashes, no leading dots, non-empty.
  local safe; safe="$(slugify "$name")"
  [ -n "$safe" ] || die "could not derive a safe folder name from '$name' (use a short kebab-case name like 'recipe-box')"
  case "$safe" in */*|.*) die "invalid folder name '$name' (slashes / leading dots not allowed)" ;; esac
  local goal; goal="$(cat "$goalfile")"
  # write ATOMICALLY: build into .tmp then mv, so the app's watcher never reads a partial marker.
  local tmp="$STATUS/project.retarget.tmp"
  printf '{"name":%s,"goal":%s}\n' "$(json_str "$safe")" "$(json_str "$goal")" > "$tmp"
  mv -f "$tmp" "$STATUS/project.retarget"
  printf 'New project "%s" — app is creating it and relaunching.\n' "$safe"
}


# a generic autonomous grid worker for ANY repo: owns a named feature/area, driven by the repo's
# own CLAUDE.md. Same todo / parallelize / handoff / spawn mechanics; framed by feature/module, not product/page.
# Write the (full) autonomous grid-worker operating manual ONCE to the session's .status dir.
ensure_grid_protocol() {
  mkdir -p "$STATUS"; printf '%s\n' "$REPO" > "$STATUS/repo"
  cat > "$STATUS/grid-protocol.md" <<EOF
# Autonomous grid-worker operating manual (claude-fleet)

You autonomously OWN one area and ship it yourself. Your identity (area, branch) is in your launch
prompt; this file is the HOW. Ship target = origin/${DBR}. Wherever it says <your-slug>, use your own
slug (the last segment of your branch, ${BR_PREFIX}/<your-slug>).

- FIRST read CLAUDE.md (repo root) + your auto-memory and FOLLOW the repo's rules (build/test/deploy
  commands, conventions, "don't touch X"). Don't re-derive what's documented.
- EVERY requirement I send is a persistent TODO — track them with TodoWrite, NEVER drop one. Several
  may arrive before you finish the first; add each, keep what's in flight, work the list IN ORDER, run
  the loop for each. PARALLELIZE BY DEPENDENCY: split a requirement into TodoWrite items; run items
  with NO unmet dependency AND NO shared file AT ONCE as parallel inline subagents (Task tool, several
  in ONE message); an item that depends on another or edits the SAME file WAITS (one worktree → clobber).
- STAY IN YOUR LANE — work in your area stays here (inline subagents, ONE worktree; never split your
  area across panes). A requirement for a DIFFERENT area (another pane's files): do NOT edit it, do NOT
  print paste-text — write the full requirement to /tmp/cfleet_handoff.txt, then route + tell me which:
    a pane already owns it (git branch --list '${BR_PREFIX}/*') → claude-fleet --handoff "<that pane>" /tmp/cfleet_handoff.txt
    no pane owns it yet → claude-fleet --spawn-grid "<area name>" /tmp/cfleet_handoff.txt
- THE LOOP — run end-to-end for each requirement:
  1. MAKE the changes for the requirement — edit freely, never pause to ask.
  2. VERIFY it works: run the repo's build/test per CLAUDE.md (run any cache-bust/build step + commit its result too).
  3. REPORT: met → print "✓ REQUIREMENT MET — <what you verified>. Ready to push."; not met/broken → "✗ NOT MET — <reason>" and keep fixing. NEVER push unmet/broken work.
  4. COMMIT on your branch — SEPARATE plain commands: \`git add <files>\` then \`git commit -m "..."\`.
  5. CHECK SIBLING BRANCHES first (shared .git, no fetch): git branch --list '${BR_PREFIX}/*'. If a sibling touched files you also touched, merge their branch in and resolve so you don't clobber them.
  6. SHIP TO ${DBR}:  git fetch origin  →  git merge origin/${DBR} (resolve, preserve both intents)  →  git push origin HEAD:${DBR} (if rejected non-fast-forward, fetch+merge origin/${DBR} again, re-push). Report the pushed commit. (Auto-deploys on push if the repo is set up that way.)
  7. UPDATE MEMORY: a concise durable note of what shipped for your area (what, why, gotchas) under that area's topic. Only touch CLAUDE.md for project-wide rules (shared — don't churn it).
EOF
}

generic_worker_prompt() { # heading slug dir [initial_requirement]
  local heading="$1" slug="$2" dir="$3" req="${4:-}"
  local intro closing repdesc
  repdesc="$(git -C "$REPO" remote get-url origin 2>/dev/null || echo "$REPO")"
  if [ -n "$req" ]; then
    intro="YOUR FIRST REQUIREMENT (handed from a sibling — this area had no pane yet). START the loop on it NOW, without asking:

${req}"
    closing="Once it ships, wait for my next requirement for \"${heading}\" and run the loop again for each."
  else
    intro="Wait for my requirement for \"${heading}\", then run the loop end-to-end WITHOUT asking permission."
    closing="Run the loop again for each follow-up requirement for \"${heading}\". Acknowledge and ask me what the requirement is."
  fi
  ensure_grid_protocol
  cat <<EOF
You are an AUTONOMOUS worker in a Claude Fleet run on ${repdesc} — pane "${heading}" (slug "${slug}"), git worktree ${dir}, branch ${BR_PREFIX}/${slug} (cut from origin/${DBR}). This pane OWNS the "${heading}" area.

READ ${STATUS}/grid-protocol.md NOW and follow it exactly — it is your operating manual: TodoWrite tracking, stay-in-lane + handoff/spawn-grid routing, and the full verify→commit→ship loop. Wherever it says <your-slug>, use "${slug}".

${intro}

${closing}
EOF
}

# the autonomous grid worker prompt for any repo
grid_worker_prompt() { generic_worker_prompt "$@"; }

# Write the (full) SHARED-multi grid-worker operating manual ONCE to the coordination .status dir. Unlike the per-repo
# grid worker, a shared worker's cwd is a WORKSPACE dir with one sub-dir per repo (each a git worktree on the worker's
# branch), so the "ship" + "self-signal" steps are per-repo and it must cd into a repo sub-dir before any git/self-signal.
ensure_shared_grid_protocol() {
  mkdir -p "$STATUS"; printf '%s\n' "$REPO" > "$STATUS/repo"
  local repolist="" r base first_base="" IFS=:
  for r in $REPOS_LIST; do
    [ -n "$r" ] || continue
    base="$(basename "${r%/}")"
    repolist="$repolist${repolist:+, }$base"
    [ -n "$first_base" ] || first_base="$base"
  done
  cat > "$STATUS/shared-grid-protocol.md" <<EOF
# Autonomous SHARED grid-worker operating manual (claude-fleet, multi-repo)

You autonomously OWN one area and ship it yourself, ACROSS SEVERAL REPOS. Your working directory contains ONE sub-dir
per repository you can work in: ${repolist}. Each sub-dir is that repo's OWN git worktree on YOUR branch
(${BR_PREFIX}/<your-slug>, cut from that repo's default branch). Edit whichever repos the requirement needs. Wherever
this file says <your-slug>, use the last segment of your branch.

- FIRST read each repo's CLAUDE.md (repo-root of each sub-dir) + your auto-memory and FOLLOW its rules (build/test/
  deploy commands, conventions, "don't touch X"). Don't re-derive what's documented.
- EVERY requirement I send is a persistent TODO — track them with TodoWrite, NEVER drop one. Several may arrive before
  you finish the first; add each, keep what's in flight, work the list IN ORDER, run the loop for each. PARALLELIZE BY
  DEPENDENCY: split a requirement into TodoWrite items; run items with NO unmet dependency AND NO shared file AT ONCE as
  parallel inline subagents (Task tool, several in ONE message); an item that depends on another or edits the SAME file
  WAITS (each repo sub-dir is ONE worktree → same-file parallelism clobbers).
- STAY IN YOUR LANE — your area, across these repos, stays in THIS pane (inline subagents; never split your area across
  panes). Work that belongs to a DIFFERENT pane's area: do NOT edit it, do NOT print paste-text — write the full
  requirement to /tmp/cfleet_handoff_<your-slug>.txt, then hand off / spawn:
    a sibling pane already owns it (claude-fleet --statuses) → claude-fleet --handoff "<that pane>" /tmp/cfleet_handoff_<your-slug>.txt
    no pane owns it yet → claude-fleet --spawn-grid "<area name>" /tmp/cfleet_handoff_<your-slug>.txt
- THE LOOP — run end-to-end for each requirement:
  1. MAKE the changes for the requirement — edit freely across whichever repo sub-dirs it needs; never pause to ask.
  2. VERIFY it works: run each touched repo's build/test per its CLAUDE.md (run any cache-bust/build step + commit its result too).
  3. REPORT: met → print "✓ REQUIREMENT MET — <what you verified>. Ready to push."; not met/broken → "✗ NOT MET — <reason>" and keep fixing. NEVER push unmet/broken work.
  4. For EACH repo you changed, from INSIDE that repo's sub-dir (\`cd <repo-basename>\`):
     a. COMMIT on your branch — SEPARATE plain commands: \`git add <files>\` then \`git commit -m "..."\`.
     b. CHECK SIBLING BRANCHES first (shared .git, no fetch): git branch --list '${BR_PREFIX}/*'. If a sibling touched files you also touched, merge their branch in and resolve so you don't clobber them.
     c. SHIP to that repo's default branch:  git fetch origin  →  git merge origin/<its default branch> (resolve, preserve both intents)  →  git push origin HEAD:<its default branch> (if rejected non-fast-forward, fetch+merge again, re-push). Report the pushed commit. (Auto-deploys on push if the repo is set up that way.) Most repos here use \`main\`; confirm per repo with \`git symbolic-ref --short refs/remotes/origin/HEAD\` (strip the \`origin/\`).
  5. SELF-SIGNAL DONE: your cwd (the workspace root) is NOT a git repo, so run this from inside ANY repo sub-dir (they're all on your branch):  cd ${first_base} && claude-fleet --done  . Same for progress pings:  cd ${first_base} && claude-fleet --status "<note>" . Re-run --done after EACH requirement; the pane stays alive for more.
  6. UPDATE MEMORY: a concise durable note of what shipped for your area (what, why, gotchas) per repo. Only touch a repo's CLAUDE.md for project-wide rules (shared — don't churn it).
EOF
}

# SHARED-multi grid worker prompt: one general pane spanning EVERY repo in CLAUDE_FLEET_REPOS. wsdir = the per-pane
# workspace dir (its cwd) whose sub-dirs (one per repo, named by basename) are that repo's worktree on the worker's branch.
grid_shared_worker_prompt() { # heading slug workspace_dir [initial_requirement]
  local heading="$1" slug="$2" wsdir="$3" req="${4:-}"
  local repolist="" r base first_base="" IFS=:
  for r in $REPOS_LIST; do
    [ -n "$r" ] || continue
    base="$(basename "${r%/}")"
    repolist="$repolist${repolist:+, }$base"
    [ -n "$first_base" ] || first_base="$base"
  done
  local intro closing
  if [ -n "$req" ]; then
    intro="YOUR FIRST REQUIREMENT. START the loop on it NOW, without asking:

${req}"
    closing="Once it ships across every repo it touches, wait for my next requirement for \"${heading}\" and run the loop again for each."
  else
    intro="Wait for my requirement for \"${heading}\", then run the loop end-to-end WITHOUT asking permission."
    closing="Run the loop again for each follow-up requirement for \"${heading}\". Acknowledge and ask me what the requirement is."
  fi
  ensure_shared_grid_protocol
  cat <<EOF
You are an AUTONOMOUS worker in a Claude Fleet MULTI-REPO run — pane "${heading}" (slug "${slug}"). Your working directory is ${wsdir}, which holds ONE sub-directory per repository you can work across: ${repolist}. Each sub-dir is that repo's own git worktree on branch ${BR_PREFIX}/${slug} (cut from that repo's default branch). You may edit ANY of them. This pane OWNS the "${heading}" area across the whole repo set.

READ ${STATUS}/shared-grid-protocol.md NOW and follow it exactly — it is your operating manual: TodoWrite tracking, per-repo verify→commit→ship, self-signal (cd into a repo sub-dir first), and stay-in-lane handoff/spawn routing. Wherever it says <your-slug>, use "${slug}". To self-signal use e.g.  cd ${first_base} && claude-fleet --done .

${intro}

${closing}
EOF
}

# Integrator mode: the SHARED multi-repo worker protocol MINUS all pushing. Workers implement across whichever repo
# sub-dirs the task needs, commit on their branch in each changed repo, then self-signal --done — the Integrator pane
# merges + tests + pushes each worker's change incrementally. Workers NEVER push, merge origin, or touch any main.
ensure_integrator_worker_protocol() {
  mkdir -p "$STATUS"; printf '%s\n' "$REPO" > "$STATUS/repo"
  local repolist="" r base first_base="" IFS=:
  for r in $REPOS_LIST; do
    [ -n "$r" ] || continue
    base="$(basename "${r%/}")"
    repolist="$repolist${repolist:+, }$base"
    [ -n "$first_base" ] || first_base="$base"
  done
  cat > "$STATUS/integrator-worker-protocol.md" <<EOF
# Autonomous worker operating manual (claude-fleet, multi-repo, Integrator mode)

You autonomously OWN one area and implement it ACROSS SEVERAL REPOS, then HAND OFF to the Integrator — you do NOT push.
Your working directory contains ONE sub-dir per repository you can work in: ${repolist}. Each sub-dir is that repo's OWN
git worktree on YOUR branch (${BR_PREFIX}/<your-slug>, cut from that repo's default branch). Edit whichever repos the
requirement needs. Wherever this file says <your-slug>, use the last segment of your branch.

- FIRST read each repo's CLAUDE.md (repo-root of each sub-dir) + your auto-memory and FOLLOW its rules (build/test/
  deploy commands, conventions, "don't touch X"). Don't re-derive what's documented.
- EVERY requirement I send is a persistent TODO — track them with TodoWrite, NEVER drop one. Several may arrive before
  you finish the first; add each, keep what's in flight, work the list IN ORDER, run the loop for each. PARALLELIZE BY
  DEPENDENCY: split a requirement into TodoWrite items; run items with NO unmet dependency AND NO shared file AT ONCE as
  parallel inline subagents (Task tool, several in ONE message); an item that depends on another or edits the SAME file
  WAITS (each repo sub-dir is ONE worktree → same-file parallelism clobbers).
- STAY IN YOUR LANE — your area, across these repos, stays in THIS pane (inline subagents; never split your area across
  panes). Work that belongs to a DIFFERENT pane's area: do NOT edit it, do NOT print paste-text — write the full
  requirement to /tmp/cfleet_handoff_<your-slug>.txt, then hand off / spawn:
    a sibling pane already owns it (claude-fleet --statuses) → claude-fleet --handoff "<that pane>" /tmp/cfleet_handoff_<your-slug>.txt
    no pane owns it yet → claude-fleet --spawn-grid "<area name>" /tmp/cfleet_handoff_<your-slug>.txt
- THE LOOP — run end-to-end for each requirement:
  1. MAKE the changes for the requirement — edit freely across whichever repo sub-dirs it needs; never pause to ask.
  2. VERIFY it works: run each touched repo's build/test per its CLAUDE.md (run any cache-bust/build step + commit its result too).
  3. REPORT: met → print "✓ REQUIREMENT MET — <what you verified>. Handing to the Integrator."; not met/broken → "✗ NOT MET — <reason>" and keep fixing. NEVER hand off unmet/broken work.
  4. For EACH repo you changed, from INSIDE that repo's sub-dir (\`cd <repo-basename>\`):
     a. COMMIT on your branch — SEPARATE plain commands: \`git add <files>\` then \`git commit -m "<what + why>"\`. Write a CLEAR message — the Integrator reads it to resolve any merge conflict.
     b. Do NOT push, do NOT \`git merge origin/<default branch>\`, do NOT checkout or touch any other branch. The Integrator merges your commit into that repo's integration checkout, tests, and pushes — you just commit.
  5. SELF-SIGNAL DONE: your cwd (the workspace root) is NOT a git repo, so run this from inside ANY repo sub-dir (they're all on your branch):  cd ${first_base} && claude-fleet --done  . The Integrator picks it up, merges each repo you changed into that repo's _main, test-gates, and pushes — incrementally, without waiting for the other panes. Re-run --done after EACH requirement; the pane stays alive for more. Progress pings:  cd ${first_base} && claude-fleet --status "<note>" .
  6. If your change DEPENDS on another pane's output, or you need a follow-up another pane must do, record it:  cd ${first_base} && claude-fleet --need "<what + why + which repos/files>"  (the Integrator surfaces it to the user; retract a mistake with  cd ${first_base} && claude-fleet --unneed ).
  7. UPDATE MEMORY: a concise durable note of what you built for your area (what, why, gotchas) per repo. Only touch a repo's CLAUDE.md for project-wide rules (shared — don't churn it).
EOF
}

# Integrator-mode worker prompt: one general pane spanning EVERY repo, but it COMMITS + --done ONLY (never pushes) — the
# Integrator pane owns integration + pushing. wsdir = the per-pane workspace dir (its cwd); sub-dirs are the repos.
integrator_worker_prompt() { # heading slug workspace_dir [initial_requirement]
  local heading="$1" slug="$2" wsdir="$3" req="${4:-}"
  local repolist="" r base first_base="" IFS=:
  for r in $REPOS_LIST; do
    [ -n "$r" ] || continue
    base="$(basename "${r%/}")"
    repolist="$repolist${repolist:+, }$base"
    [ -n "$first_base" ] || first_base="$base"
  done
  local intro closing
  if [ -n "$req" ]; then
    intro="YOUR FIRST REQUIREMENT. START the loop on it NOW, without asking:

${req}"
    closing="Once you've committed + run --done across every repo it touches, wait for my next requirement for \"${heading}\" and run the loop again for each."
  else
    intro="Wait for my requirement for \"${heading}\", then run the loop end-to-end WITHOUT asking permission."
    closing="Run the loop again for each follow-up requirement for \"${heading}\". Acknowledge and ask me what the requirement is."
  fi
  ensure_integrator_worker_protocol
  cat <<EOF
You are an AUTONOMOUS worker in a Claude Fleet MULTI-REPO run (Integrator mode) — pane "${heading}" (slug "${slug}"). Your working directory is ${wsdir}, which holds ONE sub-directory per repository you can work across: ${repolist}. Each sub-dir is that repo's own git worktree on branch ${BR_PREFIX}/${slug} (cut from that repo's default branch). You may edit ANY of them. This pane OWNS the "${heading}" area across the whole repo set.

You COMMIT your work and hand it to the INTEGRATOR pane — you do NOT push, merge origin, or touch any main. The Integrator merges each repo you changed into its integration checkout, tests, and pushes, incrementally as soon as it's safe.

READ ${STATUS}/integrator-worker-protocol.md NOW and follow it exactly — it is your operating manual: TodoWrite tracking, per-repo verify→commit (NO push), self-signal (cd into a repo sub-dir first), and stay-in-lane handoff/spawn routing. Wherever it says <your-slug>, use "${slug}". To self-signal use e.g.  cd ${first_base} && claude-fleet --done .

${intro}

${closing}
EOF
}

# Grid mode: N named, autonomous worker panes for the selected repo; each verifies + pushes to its default branch
cmd_grid_plan() { # <N> <name1> <name2> ...
  local n="$1"; shift
  [ -n "$n" ] || die "--grid-plan needs a count"
  [ -d "$REPO/.git" ] || die "not a git repository: $REPO"
  fetch_origin
  set_default_branch
  reset_state
  local -a W_SLUG W_HEAD W_DIR
  local idx=0 name slug branch dir
  for name in "$@"; do
    idx=$((idx + 1)); [ "$idx" -le "$n" ] || break
    slug="$(slugify "$name")"; [ -n "$slug" ] || slug="grid-$idx"
    branch="$BR_PREFIX/$slug"; dir="$FLEET/$slug"
    if [ -d "$dir" ]; then :
    elif git -C "$REPO" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$REPO" worktree add "$dir" "$branch" >&2
    else
      git -C "$REPO" worktree add -b "$branch" "$dir" "origin/$DBR" >/dev/null 2>&1 \
        || git -C "$REPO" worktree add -b "$branch" "$dir" "$DBR" >&2
    fi
    link_shared_dirs "$dir"
    rm -f "$STATUS/$slug.done" "$STATUS/$slug.merged"
    printf '%s\n' "$slug" >> "$MANIFEST"
    W_SLUG+=("$slug"); W_HEAD+=("$name"); W_DIR+=("$dir")
  done
  printf '['
  local first=1 i
  for i in "${!W_SLUG[@]}"; do
    [ "$first" = 1 ] && first=0 || printf ','
    printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"prompt":%s}' \
      "$(json_str "${W_SLUG[$i]}")" "$(json_str "${W_HEAD[$i]}")" "$(json_str "${W_DIR[$i]}")" \
      "$(json_str "$(grid_worker_prompt "${W_HEAD[$i]}" "${W_SLUG[$i]}" "${W_DIR[$i]}")")"
  done
  printf ']\n'
}

# Multi-repo GRID (no orchestrator): ONE named worker pane PER repo in CLAUDE_FLEET_REPOS, each cut into that repo's
# OWN fleet worktree (fleet/s<sid>/<slug>), each self-pushing its own repo. Mirrors cmd_grid_plan's worktree creation
# but iterates the repo set like the multi orchestrator: STATUS stays the shared coordination dir (so the manifest +
# GC markers live on the one board), and each emitted pane is tagged with its absolute repo path ("repo") so the app
# spawns it with CLAUDE_FLEET_REPO=that repo. Writes the coord `members` + per-member `.status/repo` gc markers +
# per-slug `.repo` sidecars, matching the orchestrated multi path so --handoff/--gc-all resolve correctly.
cmd_grid_plan_multi() { # [heading1 heading2 ...]  optional per-repo pane names, parallel to CLAUDE_FLEET_REPOS order
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--grid-plan-multi is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--grid-plan-multi needs CLAUDE_FLEET_REPOS"
  local -a NAMES=("$@")                           # optional per-repo HEADINGS (parallel to REPOS_LIST); blank/absent → basename. Display-only: worktree dir/slug/branch stay keyed on basename.
  assert_unique_repo_basenames                   # fail loud on duplicate basenames (would collide onto one fleet)
  reset_state                                    # coordination STATUS (CLAUDE_FLEET_STATUS_DIR); manifest seeded (REPO=coord)
  local r slug branch dir name heading ri=0
  local -a member_fleets=() P_SLUG P_HEAD P_DIR P_REPO P_PROMPT
  local IFS=:
  for r in $REPOS_LIST; do
    [ -d "$r/.git" ] || die "not a git repository: $r"
    select_repo "$r"; fetch_origin               # re-points REPO/FLEET/DBR to this repo (STATUS stays the coord dir)
    name="$(basename "$REPO")"; slug="$(slugify "$name")"; [ -n "$slug" ] || slug="repo"
    heading="${NAMES[$ri]:-}"; [ -n "$heading" ] || heading="$name"   # custom pane name (display/prompt only); slug/dir/branch stay from basename
    ri=$((ri + 1))
    branch="$BR_PREFIX/$slug"; dir="$FLEET/$slug"
    if [ -d "$dir" ]; then :
    elif git -C "$REPO" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$REPO" worktree add "$dir" "$branch" >&2
    else
      git -C "$REPO" worktree add -b "$branch" "$dir" "origin/$DBR" >/dev/null 2>&1 \
        || git -C "$REPO" worktree add -b "$branch" "$dir" "$DBR" >&2
    fi
    link_shared_dirs "$dir"
    rm -f "$STATUS/$slug.done" "$STATUS/$slug.merged" "$STATUS/$slug.closed" "$STATUS/$slug.working"
    printf '%s\n' "$slug" >> "$MANIFEST"
    printf '%s\n' "$REPO" > "$STATUS/$slug.repo"           # per-slug repo sidecar (parity with --spawn --repo)
    mkdir -p "$FLEET/.status"; printf '%s\n' "$REPO" > "$FLEET/.status/repo"   # member fleet gc marker (G0-G4)
    member_fleets+=("$FLEET")
    # generate the prompt NOW, while REPO/DBR point at this repo (generic_worker_prompt reads origin/$DBR from $REPO)
    P_SLUG+=("$slug"); P_HEAD+=("$heading"); P_DIR+=("$dir"); P_REPO+=("$REPO")
    P_PROMPT+=("$(grid_worker_prompt "$heading" "$slug" "$dir")")
  done
  local coord; coord="$(dirname "$STATUS")"       # the coordination dir (parent of .status)
  mkdir -p "$coord/.status"
  printf '%s\n' "${member_fleets[@]}" > "$coord/.status/members"   # gc: reap coord only once every member fleet is gone
  printf '['
  local first=1 i
  for i in "${!P_SLUG[@]}"; do
    [ "$first" = 1 ] && first=0 || printf ','
    printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"repo":%s,"prompt":%s}' \
      "$(json_str "${P_SLUG[$i]}")" "$(json_str "${P_HEAD[$i]}")" "$(json_str "${P_DIR[$i]}")" \
      "$(json_str "${P_REPO[$i]}")" "$(json_str "${P_PROMPT[$i]}")"
  done
  printf ']\n'
}

# Multi-repo SHARED GRID (no orchestrator): N GENERAL worker panes, each spanning EVERY repo in CLAUDE_FLEET_REPOS.
# Unlike cmd_grid_plan_multi (one pane pinned per repo), here EACH of the N pane slugs gets a worktree in EVERY repo on
# branch fleet/s<sid>/<slug>, plus a per-pane WORKSPACE dir (<coord>/workers/<slug>/) holding one symlink per repo
# (named by basename) into that repo's <repo>-fleet-<sid>/<slug> worktree — so the pane's ONE cwd exposes all repos.
# STATUS stays the shared coordination dir. Writes the coord `members` gc marker + each member fleet's `.status/repo`
# marker + a per-slug `.repo` sidecar (first member, for --handoff liveness), matching the orchestrated multi path so
# GC + --handoff resolve. Emits pane JSON WITHOUT a "repo" tag (each pane spans them all).
cmd_grid_plan_shared() { # <N> [name1 name2 ...]
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--grid-plan-shared is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--grid-plan-shared needs CLAUDE_FLEET_REPOS"
  local n="$1"; shift || true
  [ -n "$n" ] || die "--grid-plan-shared needs a count"
  assert_unique_repo_basenames                   # fail loud on duplicate basenames (would collide onto one fleet)
  reset_state                                    # coordination STATUS (CLAUDE_FLEET_STATUS_DIR); manifest seeded (REPO=coord)
  local coord; coord="$(dirname "$STATUS")"      # the coordination dir (parent of .status)
  # 1) derive the N pane slugs + headings from names (blank/absent → pane-<i>); dedup slugs (each maps to a worktree
  #    in EVERY repo, so two panes on one slug would collide onto the same branch/dir). bash-3.2: seen = spaced string.
  local -a P_SLUG P_HEAD
  local idx=0 name slug base k seen=" "
  for name in "$@"; do
    idx=$((idx + 1)); [ "$idx" -le "$n" ] || break
    slug="$(slugify "$name")"; [ -n "$slug" ] || slug="pane-$idx"
    base="$slug"; k=2
    while case "$seen" in *" $slug "*) true ;; *) false ;; esac; do slug="$base-$k"; k=$((k + 1)); done
    seen="$seen$slug "
    P_SLUG+=("$slug"); P_HEAD+=("$name")
  done
  [ "${#P_SLUG[@]}" -gt 0 ] || die "--grid-plan-shared needs at least one pane name"
  # 2) for EACH repo: create every pane's worktree in it + wire the workspace symlinks; collect member fleets for gc.
  local -a member_fleets=()
  local r rbase wslug wdir branch first_repo="" i
  local IFS=:
  for r in $REPOS_LIST; do
    [ -d "$r/.git" ] || die "not a git repository: $r"
    select_repo "$r"; fetch_origin              # re-points REPO/FLEET/DBR to this repo (STATUS stays the coord dir)
    [ -n "$first_repo" ] || first_repo="$REPO"
    rbase="$(basename "$REPO")"
    mkdir -p "$FLEET/.status"; printf '%s\n' "$REPO" > "$FLEET/.status/repo"   # member fleet gc marker (G0-G4)
    member_fleets+=("$FLEET")
    for i in "${!P_SLUG[@]}"; do
      wslug="${P_SLUG[$i]}"; branch="$BR_PREFIX/$wslug"; wdir="$FLEET/$wslug"
      if [ -d "$wdir" ]; then :
      elif git -C "$REPO" show-ref --verify --quiet "refs/heads/$branch"; then
        git -C "$REPO" worktree add "$wdir" "$branch" >&2
      else
        git -C "$REPO" worktree add -b "$branch" "$wdir" "origin/$DBR" >/dev/null 2>&1 \
          || git -C "$REPO" worktree add -b "$branch" "$wdir" "$DBR" >&2
      fi
      link_shared_dirs "$wdir"
      mkdir -p "$coord/workers/$wslug"
      ln -sfn "$wdir" "$coord/workers/$wslug/$rbase"   # the pane's cwd exposes this repo as ./<basename> (-n: replace an existing symlink-to-dir)
    done
  done
  # 3) per-slug board state on the shared coord (slug-keyed, once per pane): manifest + reset markers + .repo sidecar.
  for i in "${!P_SLUG[@]}"; do
    wslug="${P_SLUG[$i]}"
    printf '%s\n' "$wslug" >> "$MANIFEST"
    rm -f "$STATUS/$wslug.done" "$STATUS/$wslug.merged" "$STATUS/$wslug.closed" "$STATUS/$wslug.working"
    printf '%s\n' "$first_repo" > "$STATUS/$wslug.repo"   # sidecar → first member (any works for --handoff liveness)
  done
  mkdir -p "$coord/.status"
  printf '%s\n' "${member_fleets[@]}" > "$coord/.status/members"   # gc: reap coord only once every member fleet is gone
  # 4) emit pane JSON — cwd = the per-pane workspace dir; NO "repo" tag (each pane spans every repo).
  printf '['
  local firstj=1
  for i in "${!P_SLUG[@]}"; do
    [ "$firstj" = 1 ] && firstj=0 || printf ','
    wslug="${P_SLUG[$i]}"
    printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"prompt":%s}' \
      "$(json_str "$wslug")" "$(json_str "${P_HEAD[$i]}")" "$(json_str "$coord/workers/$wslug")" \
      "$(json_str "$(grid_shared_worker_prompt "${P_HEAD[$i]}" "$wslug" "$coord/workers/$wslug")")"
  done
  printf ']\n'
}

# Multi-repo INTEGRATOR mode (no orchestrator, + a dedicated Integrator pane). Like cmd_grid_plan_shared (N GENERAL
# worker panes, each spanning EVERY repo: a worktree per (pane × repo) on fleet/s<sid>/<slug> + a per-pane workspace dir
# symlinking each repo's worktree, used as the pane's cwd) but ALSO: (a) create each repo's _main integration checkout
# (the Integrator merges worker branches into it + pushes it), (b) workers commit + --done only — integrator_worker_prompt,
# NO self-push, and (c) emit an EXTRA fixed "Integrator" pane (cwd = coord dir) whose prompt is the integrate-only loop.
# STATUS stays the shared coordination dir; writes the same coord `members` + member `.status/repo` gc markers as the
# orchestrated multi path. Reserves the "integrator" slug so no worker can collide with the Integrator pane's slug.
cmd_grid_plan_integrator() { # <N> [name1 name2 ...]
  [ "${CLAUDE_FLEET_MULTI:-}" = 1 ] || die "--grid-plan-integrator is multi-repo only (set CLAUDE_FLEET_MULTI=1 + CLAUDE_FLEET_REPOS)"
  [ -n "$REPOS_LIST" ] || die "--grid-plan-integrator needs CLAUDE_FLEET_REPOS"
  local n="$1"; shift || true
  [ -n "$n" ] || die "--grid-plan-integrator needs a count"
  assert_unique_repo_basenames                   # fail loud on duplicate basenames (would collide onto one fleet)
  reset_state                                    # coordination STATUS (CLAUDE_FLEET_STATUS_DIR); manifest seeded (REPO=coord)
  local coord; coord="$(dirname "$STATUS")"      # the coordination dir (parent of .status)
  # 1) derive the N worker slugs + headings from names (blank/absent → pane-<i>); dedup slugs. Seed `seen` with
  #    "integrator" so a worker can never take that slug (it's reserved for the Integrator pane). bash-3.2: spaced string.
  local -a P_SLUG P_HEAD
  local idx=0 name slug base k seen=" integrator "
  for name in "$@"; do
    idx=$((idx + 1)); [ "$idx" -le "$n" ] || break
    slug="$(slugify "$name")"; [ -n "$slug" ] || slug="pane-$idx"
    base="$slug"; k=2
    while case "$seen" in *" $slug "*) true ;; *) false ;; esac; do slug="$base-$k"; k=$((k + 1)); done
    seen="$seen$slug "
    P_SLUG+=("$slug"); P_HEAD+=("$name")
  done
  [ "${#P_SLUG[@]}" -gt 0 ] || die "--grid-plan-integrator needs at least one pane name"
  # 2) for EACH repo: create its _main integration checkout + every worker pane's worktree + wire the workspace symlinks.
  local -a member_fleets=()
  local r rbase wslug wdir branch odir first_repo="" i
  local IFS=:
  for r in $REPOS_LIST; do
    [ -d "$r/.git" ] || die "not a git repository: $r"
    select_repo "$r"; fetch_origin              # re-points REPO/FLEET/DBR to this repo (STATUS stays the coord dir)
    [ -n "$first_repo" ] || first_repo="$REPO"
    rbase="$(basename "$REPO")"
    odir="$FLEET/_main"                          # the Integrator's integration checkout for this repo (detached at DBR tip)
    if [ ! -d "$odir" ]; then
      git -C "$REPO" worktree add --detach "$odir" "origin/$DBR" >&2 2>/dev/null \
        || git -C "$REPO" worktree add --detach "$odir" "$DBR" >&2
    fi
    link_shared_dirs "$odir"
    mkdir -p "$FLEET/.status"; printf '%s\n' "$REPO" > "$FLEET/.status/repo"   # member fleet gc marker (G0-G4)
    member_fleets+=("$FLEET")
    for i in "${!P_SLUG[@]}"; do
      wslug="${P_SLUG[$i]}"; branch="$BR_PREFIX/$wslug"; wdir="$FLEET/$wslug"
      if [ -d "$wdir" ]; then :
      elif git -C "$REPO" show-ref --verify --quiet "refs/heads/$branch"; then
        git -C "$REPO" worktree add "$wdir" "$branch" >&2
      else
        git -C "$REPO" worktree add -b "$branch" "$wdir" "origin/$DBR" >/dev/null 2>&1 \
          || git -C "$REPO" worktree add -b "$branch" "$wdir" "$DBR" >&2
      fi
      link_shared_dirs "$wdir"
      mkdir -p "$coord/workers/$wslug"
      ln -sfn "$wdir" "$coord/workers/$wslug/$rbase"   # the pane's cwd exposes this repo as ./<basename> (-n: replace an existing symlink-to-dir)
    done
  done
  # 3) per-slug board state on the shared coord (slug-keyed, once per pane): manifest + reset markers + .repo sidecar.
  for i in "${!P_SLUG[@]}"; do
    wslug="${P_SLUG[$i]}"
    printf '%s\n' "$wslug" >> "$MANIFEST"
    rm -f "$STATUS/$wslug.done" "$STATUS/$wslug.merged" "$STATUS/$wslug.closed" "$STATUS/$wslug.working"
    printf '%s\n' "$first_repo" > "$STATUS/$wslug.repo"   # sidecar → first member (any works for --handoff liveness)
  done
  mkdir -p "$coord/.status"
  printf '%s\n' "${member_fleets[@]}" > "$coord/.status/members"   # gc: reap coord only once every member fleet is gone
  # 4) emit pane JSON — N worker panes (workspace cwd, no "repo" tag, commit + --done only) + the fixed Integrator pane
  #    (cwd = coord dir, integrate-only prompt, xhigh effort → max reasoning for conflict resolution / coordination).
  printf '['
  local firstj=1
  for i in "${!P_SLUG[@]}"; do
    [ "$firstj" = 1 ] && firstj=0 || printf ','
    wslug="${P_SLUG[$i]}"
    printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"prompt":%s}' \
      "$(json_str "$wslug")" "$(json_str "${P_HEAD[$i]}")" "$(json_str "$coord/workers/$wslug")" \
      "$(json_str "$(integrator_worker_prompt "${P_HEAD[$i]}" "$wslug" "$coord/workers/$wslug")")"
  done
  printf ',{"role":"integrator","slug":"integrator","heading":"Integrator","dir":%s,"effort":"xhigh","prompt":%s}' \
    "$(json_str "$coord")" "$(json_str "$(spawn_integrator_prompt "$coord")")"
  printf ']\n'
}

# Grid mode: add ONE more named worker to an ALREADY-RUNNING fleet (no state reset). Emits a single
# JSON object the app turns into a new pane — same shape as one element of --grid-plan's array.
cmd_grid_add() { # <name>
  local name="$1"
  [ -n "$name" ] || die "--grid-add needs a worker name"
  [ -d "$REPO/.git" ] || die "not a git repository: $REPO"
  [ -d "$STATUS" ] || die "no active grid session"
  fetch_origin
  set_default_branch
  local slug base k=2 branch dir
  slug="$(slugify "$name")"; [ -n "$slug" ] || slug="grid"; base="$slug"
  while [ -d "$FLEET/$slug" ] || grep -qx "$slug" "$MANIFEST" 2>/dev/null; do slug="$base-$k"; k=$((k + 1)); done
  branch="$BR_PREFIX/$slug"; dir="$FLEET/$slug"
  git -C "$REPO" worktree add -b "$branch" "$dir" "origin/$DBR" >/dev/null 2>&1 \
    || git -C "$REPO" worktree add -b "$branch" "$dir" "$DBR" >&2
  link_shared_dirs "$dir"
  rm -f "$STATUS/$slug.done" "$STATUS/$slug.merged"
  printf '%s\n' "$slug" >> "$MANIFEST"
  printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"prompt":%s}\n' \
    "$(json_str "$slug")" "$(json_str "$name")" "$(json_str "$dir")" \
    "$(json_str "$(grid_worker_prompt "$name" "$slug" "$dir")")"
}

# Grid mode: a worker SPAWNS a brand-new worker pane for an area NO pane owns yet, seeded with the
# requirement (read from FILE so the command stays static). Writes a .spawn marker — the same channel the
# dispatch orchestrator uses — which the app turns into a new pane that starts working immediately.
cmd_grid_spawn() { # <name> <task-file>
  local name="$1" path="$2"
  [ -n "$name" ] && [ -n "$path" ] || die "--spawn-grid needs <area-name> <task-file>"
  [ -f "$path" ] || die "task file not found: $path"
  [ -d "$STATUS" ] || die "no active grid session"
  fetch_origin
  set_default_branch
  local slug base k=2 branch dir req
  req="$(cat "$path")"
  slug="$(slugify "$name")"; [ -n "$slug" ] || slug="grid"; base="$slug"
  while [ -d "$FLEET/$slug" ] || grep -qx "$slug" "$MANIFEST" 2>/dev/null; do slug="$base-$k"; k=$((k + 1)); done
  branch="$BR_PREFIX/$slug"; dir="$FLEET/$slug"
  git -C "$REPO" worktree add -b "$branch" "$dir" "origin/$DBR" >/dev/null 2>&1 \
    || git -C "$REPO" worktree add -b "$branch" "$dir" "$DBR" >&2
  link_shared_dirs "$dir"
  rm -f "$STATUS/$slug.done" "$STATUS/$slug.merged"
  printf '%s\n' "$slug" >> "$MANIFEST"
  printf '{"role":"worker","slug":%s,"heading":%s,"dir":%s,"prompt":%s}' \
    "$(json_str "$slug")" "$(json_str "$name")" "$(json_str "$dir")" \
    "$(json_str "$(grid_worker_prompt "$name" "$slug" "$dir" "$req")")" > "$STATUS/$slug.spawn.tmp"
  mv -f "$STATUS/$slug.spawn.tmp" "$STATUS/$slug.spawn"   # atomic: app's fs.watch never reads a partial marker
  printf 'Spawned new product pane "%s" (%s), seeded with the requirement. It is working now.\n' "$name" "$slug"
}

# ---------------------------------------------------------------- dispatch
if [ "${CFLEET_NO_MAIN:-}" != 1 ]; then
gh_align   # align gh active account to origin owner before any git/gh work (self-guarded, non-fatal)
ensure_git_identity   # guarantee a valid commit author for the top-level (single-repo) $REPO (no-op if already valid)

case "${1:-}" in
  --orchestrator) cmd_orchestrator ;;
  --grid-plan)    shift; cmd_grid_plan "$@" ;;
  --grid-plan-multi) shift; cmd_grid_plan_multi "$@" ;;
  --grid-plan-shared) shift; cmd_grid_plan_shared "$@" ;;
  --grid-plan-integrator) shift; cmd_grid_plan_integrator "$@" ;;
  --grid-add)     shift; cmd_grid_add "${1:-}" ;;
  --spawn)        shift; cmd_spawn "$@" ;;
  --spawn-file)   shift; cmd_spawn_file "$@" ;;
  --handoff)      shift; cmd_handoff "${1:-}" "${2:-}" ;;
  --spawn-grid)   shift; cmd_grid_spawn "${1:-}" "${2:-}" ;;
  --done)         cmd_done ;;
  --next)         cmd_next ;;
  --watch)        cmd_watch ;;
  --merged)       shift; cmd_merged "${1:-}" ;;
  --ready)        cmd_ready ;;
  --failed)       cmd_failed ;;
  --conflicts)    cmd_conflicts ;;
  --need)         shift; cmd_need "${1:-}" ;;
  --needs)        cmd_needs ;;
  --need-clear)   shift; cmd_need_clear "${1:-}" ;;
  --unneed)       cmd_unneed ;;
  --status)       shift; cmd_status "${1:-}" ;;
  --statuses)     cmd_statuses ;;
  --rebuild)      cmd_rebuild ;;
  --ship-all)     cmd_ship_all ;;
  --ship)         shift; cmd_ship "$@" ;;
  --touched)      shift; cmd_touched "${1:-}" ;;
  --new-project)  shift; cmd_new_project "${1:-}" "${2:-}" ;;
  --clean)        cmd_clean ;;
  --gc)           cmd_gc ;;
  --gc-all)       shift; cmd_gc_all "${1:-}" ;;
  --gh-align)     gh_align; echo "gh active account: $(gh auth status --active 2>/dev/null | sed -nE 's/.*Logged in to github\.com account ([^ ]+).*/\1/p' | head -1)" ;;
  -h|--help)      awk 'NR>1 && /^#/{sub(/^# ?/,"");print;next} NR>1{exit}' "$0" ;;
  *)              die "unknown arg: ${1:-} (try --help)" ;;
esac
fi
